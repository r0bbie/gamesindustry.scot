# Critic score fetching
# Sign up free at https://rapidapi.com/opencritic-opencritic-default/api/opencritic-api
# Scores are fetched at build time and cached in data/cache/critic-scores.json
RAPIDAPI_KEY=your_key_here

# Cloudflare R2 — cover art uploads (scripts/upload-cover-art.mjs)
# Create an R2 API token at https://dash.cloudflare.com/ → R2 → Manage API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Optional: purge Cloudflare CDN cache when upload-cover-art.mjs replaces an existing cover
# (API token: Zone → Cache Purge → Purge; zone ID from the site that serves media.gamesindustry.scot)
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
