---
/**
 * RandomPick: wraps a pool of items and shows `show` of them at random on every page load.
 *
 * Astro builds static HTML, so any `Math.random()` shuffle in frontmatter is baked in at build time
 * and stays fixed in production until the next deploy. RandomPick keeps everything static — render
 * up to N candidates inside this wrapper (cap it sensibly, e.g. 20) and the parent should set
 * `hidden` on the items it wants hidden in the no-JS / pre-script SSR fallback (typically those
 * past the visible count). On load, a tiny client script picks a fresh random subset on every visit.
 */

interface Props {
  show?: number;
  class?: string;
}

const { show = 4, class: className } = Astro.props;
---

<div class:list={[className]} data-random-pool data-show={show}>
  <slot />
</div>

<script>
  function initRandomPool(pool: HTMLElement) {
    const show = Math.max(0, Number(pool.dataset.show ?? "4"));
    const children = Array.from(pool.children) as HTMLElement[];
    if (children.length === 0) return;
    if (children.length <= show) {
      children.forEach((c) => c.removeAttribute("hidden"));
      return;
    }
    const indices = children.map((_, i) => i);
    for (let i = indices.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [indices[i], indices[j]] = [indices[j], indices[i]];
    }
    const picked = new Set(indices.slice(0, show));
    children.forEach((c, i) => {
      if (picked.has(i)) c.removeAttribute("hidden");
      else c.setAttribute("hidden", "");
    });
  }

  document
    .querySelectorAll<HTMLElement>("[data-random-pool]")
    .forEach(initRandomPool);
</script>
