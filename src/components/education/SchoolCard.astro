---
import type { School } from "@/lib/data";

interface Props {
  school: School;
}

const { school } = Astro.props;
const iconBg = school.logo_bg === "light" ? "bg-white" : school.logo_bg === "dark" ? "bg-zinc-900" : "bg-muted";
---

<a
  href={`/education/schools/${school.slug}`}
  class="group rounded-xl border border-border bg-card text-card-foreground shadow transition-colors hover:border-primary/30 hover:shadow-md"
>
  <div class="flex flex-col p-5">
    <div class={`mb-3 flex h-12 w-12 items-center justify-center rounded-lg ${iconBg}`}>
      {(school.icon ?? school.logo) ? (
        <img src={school.icon ?? school.logo} alt={school.name} class="h-10 w-10 rounded-md object-contain" />
      ) : (
        <svg class="h-6 w-6 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
          <path d="M6 12v5c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2v-5" />
        </svg>
      )}
    </div>
    <h3 class="font-semibold leading-none tracking-tight group-hover:text-primary transition-colors">
      {school.name}
    </h3>
    {school.hq && (
      <p class="mt-1.5 flex items-center gap-1 text-xs text-muted-foreground">
        <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        {school.hq}
      </p>
    )}
    {school.about && (
      <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">
        {school.about}
      </p>
    )}
  </div>
</a>
