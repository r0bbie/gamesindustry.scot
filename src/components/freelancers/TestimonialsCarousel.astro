---
/**
 * Testimonials carousel for freelancer profiles.
 * - Hides itself if there are zero items.
 * - Renders a single static blockquote when there's exactly one.
 * - For 2+ items, renders a snap-scrolling carousel with prev/next buttons,
 *   clickable dot indicators, and keyboard arrow navigation.
 *
 * The page can pass any number of testimonials; only the first `max` are shown
 * (default 10).
 */

interface Testimonial {
  quote: string;
  attribution: string;
}

interface Props {
  testimonials: Testimonial[];
  max?: number;
}

const { testimonials, max = 10 } = Astro.props;
const items = testimonials.slice(0, max);
const total = items.length;
---

{total > 0 && (
  <div class="mb-8">
    <h2 class="mb-4 text-xl font-semibold">Testimonials</h2>
    {total === 1 ? (
      <blockquote class="rounded-lg border border-border bg-muted/40 px-6 py-5">
        <p class="testimonial-quote whitespace-pre-line leading-relaxed text-muted-foreground">{items[0].quote}</p>
        <footer class="mt-3 text-sm font-medium">— {items[0].attribution}</footer>
      </blockquote>
    ) : (
      <div
        data-testimonial-carousel
        class="relative"
        role="region"
        aria-roledescription="carousel"
        aria-label="Testimonials"
        tabindex="0"
      >
        <div
          data-track
          class="testimonial-track flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth"
        >
          {items.map(({ quote, attribution }, i) => (
            <blockquote
              data-slide
              data-index={i}
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} of ${total}`}
              class="snap-start shrink-0 basis-full rounded-lg border border-border bg-muted/40 px-6 py-5"
            >
              <p class="testimonial-quote whitespace-pre-line leading-relaxed text-muted-foreground">{quote}</p>
              <footer class="mt-3 text-sm font-medium">— {attribution}</footer>
            </blockquote>
          ))}
        </div>
        <div class="mt-4 flex items-center justify-center gap-3">
          <button
            data-prev
            type="button"
            aria-label="Previous testimonial"
            class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border bg-background text-muted-foreground shadow-sm transition-colors hover:bg-accent hover:text-foreground disabled:cursor-not-allowed disabled:opacity-40"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <div class="flex items-center gap-1.5">
            {items.map((_, i) => (
              <button
                data-dot
                data-index={i}
                type="button"
                aria-label={`Go to testimonial ${i + 1}`}
                aria-current={i === 0 ? "true" : "false"}
                class="testimonial-dot h-2 w-2 rounded-full bg-muted-foreground/40 transition-all hover:bg-muted-foreground/70"
              ></button>
            ))}
          </div>
          <button
            data-next
            type="button"
            aria-label="Next testimonial"
            class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border bg-background text-muted-foreground shadow-sm transition-colors hover:bg-accent hover:text-foreground disabled:cursor-not-allowed disabled:opacity-40"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    )}
  </div>
)}

<style>
  .testimonial-quote::before,
  .testimonial-quote::after {
    content: "\"";
  }

  .testimonial-track {
    scrollbar-width: none;
  }
  .testimonial-track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-dot[aria-current="true"] {
    background-color: hsl(var(--foreground));
    width: 1rem;
  }
</style>

<script>
  function initTestimonialCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-track]");
    if (!track) return;
    const slides = Array.from(track.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dot]"));
    const prev = root.querySelector<HTMLButtonElement>("[data-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-next]");
    if (slides.length <= 1) return;

    let active = 0;

    function setActive(i: number) {
      active = Math.max(0, Math.min(slides.length - 1, i));
      dots.forEach((dot, idx) => {
        dot.setAttribute("aria-current", idx === active ? "true" : "false");
      });
      if (prev) prev.disabled = active === 0;
      if (next) next.disabled = active === slides.length - 1;
    }

    function scrollToSlide(i: number) {
      const target = slides[i];
      if (!target || !track) return;
      track.scrollTo({
        left: target.offsetLeft - track.offsetLeft,
        behavior: "smooth",
      });
    }

    const AUTOPLAY_MS = 10_000;
    let timer: ReturnType<typeof setTimeout> | null = null;

    function startAutoplay() {
      if (timer !== null) return;
      timer = setTimeout(function advance() {
        const next_idx = active < slides.length - 1 ? active + 1 : 0;
        scrollToSlide(next_idx);
        timer = setTimeout(advance, AUTOPLAY_MS);
      }, AUTOPLAY_MS);
    }

    function stopAutoplay() {
      if (timer !== null) {
        clearTimeout(timer);
        timer = null;
      }
    }

    function onUserInteraction() {
      stopAutoplay();
      startAutoplay();
    }

    prev?.addEventListener("click", () => { scrollToSlide(active - 1); onUserInteraction(); });
    next?.addEventListener("click", () => { scrollToSlide(active + 1); onUserInteraction(); });
    dots.forEach((dot, i) =>
      dot.addEventListener("click", () => { scrollToSlide(i); onUserInteraction(); }),
    );

    root.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        scrollToSlide(active - 1);
        onUserInteraction();
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        scrollToSlide(active + 1);
        onUserInteraction();
      }
    });

    // Pause while the user hovers/touches the carousel
    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);
    root.addEventListener("touchstart", stopAutoplay, { passive: true });
    root.addEventListener("touchend", startAutoplay, { passive: true });

    const io = new IntersectionObserver(
      (entries) => {
        let best: { idx: number; ratio: number } | null = null;
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const idx = Number((entry.target as HTMLElement).dataset.index);
          if (!best || entry.intersectionRatio > best.ratio) {
            best = { idx, ratio: entry.intersectionRatio };
          }
        }
        if (best) setActive(best.idx);
      },
      { root: track, threshold: [0.6] },
    );
    slides.forEach((slide) => io.observe(slide));

    setActive(0);
    startAutoplay();
  }

  document
    .querySelectorAll<HTMLElement>("[data-testimonial-carousel]")
    .forEach(initTestimonialCarousel);
</script>
