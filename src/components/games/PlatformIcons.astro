---
import { getAllPlatforms } from "@/lib/data";
import { simpleIconPath } from "@/lib/simpleIconPath";

interface Props {
  platforms: string[];
  size?: "sm" | "md";
}

const { platforms, size = "sm" } = Astro.props;
const allPlatforms = await getAllPlatforms();
const platformMap = new Map(allPlatforms.map((p) => [p.id, p]));

const sizeClasses = {
  sm: "px-1.5 py-0.5 text-[10px]",
  md: "px-2 py-0.5 text-xs",
};
const iconSizeClasses = {
  sm: "h-2.5 w-2.5 shrink-0",
  md: "h-3 w-3 shrink-0",
};

// Map platform ID → Simple Icons slug
