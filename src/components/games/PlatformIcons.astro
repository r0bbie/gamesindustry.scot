const customIcons: Record<string, IconInfo> = {
    xbox:             { path: xboxSphere, viewBox: "0 0 575.568 575.568" },
    "xbox-360":       { path: xboxSphere, viewBox: "0 0 575.568 575.568" },
    "xbox-one":       { path: xboxSphere, viewBox: "0 0 575.568 575.568" },
    "xbox-series-xs": { path: xboxSphere, viewBox: "0 0 575.568 575.568" },
  switch:           { path: switchPath, viewBox: "0 0 32 32" },
  "switch-2":       { path: switchPath, viewBox: "0 0 32 32" },
  gamecube:         { path: gamecubePath, viewBox: "0 0 32 32" },
  n64:              { path: nintendoN,  viewBox: "0 0 24 24" },
    snes:             { path: snesPath,   viewBox: "0 0 48 48" },
  nes:              { path: nintendoN,  viewBox: "0 0 24 24" },
    wii:              { path: wiiPath,    viewBox: "0 0 24 24" },
    "wii-u":          { path: wiiUPath,   viewBox: "0 0 94.2 26.6" },
  "game-boy":       { path: nintendoN,  viewBox: "0 0 24 24" },
  "game-boy-advance": { path: nintendoN, viewBox: "0 0 24 24" },
  "3ds":            { path: nintendoN,  viewBox: "0 0 24 24" },
  ds:               { path: nintendoN,  viewBox: "0 0 24 24" },
  vr:               { path: vrHeadset, viewBox: "0 0 24 24" },
  pico:             { path: vrHeadset, viewBox: "0 0 24 24" },
};

function getIconInfo(id: string): IconInfo | null {
  const slug = simpleIconSlug[id];
  if (slug) {
    const path = simpleIconPath(slug);
    if (path) return { path, viewBox: "0 0 24 24" };
  }
  return customIcons[id] ?? null;
}
---

{platforms.length > 0 && (
  <div class="flex flex-wrap gap-1">
    {platforms.map((id) => {
      const platform = platformMap.get(id);
      const iconInfo = getIconInfo(id);
      return (
        <span
          class:list={[
            "inline-flex items-center gap-1 rounded-md bg-secondary text-secondary-foreground font-medium",
            sizeClasses[size],
          ]}
          title={platform?.description ?? id}
        >
          {iconInfo ? (
            <svg
              class={iconSizeClasses[size]}
              viewBox={iconInfo.viewBox}
              fill="currentColor"
              aria-hidden="true"
              set:html={`<path d="${iconInfo.path}"/>`}
            />
          ) : (
            <svg
              class={iconSizeClasses[size]}
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="20" height="12" x="2" y="6" rx="2" />
              <path d="M12 12h.01" />
              <path d="M17 12h.01" />
              <path d="M7 12h4" />
              <path d="M9 10v4" />
            </svg>
          )}
          {platform?.name ?? id}
        </span>
      );
    })}
  </div>
)}
