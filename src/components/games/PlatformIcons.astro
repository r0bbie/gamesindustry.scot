---
import { getAllPlatforms } from "@/lib/data";
import { simpleIconPath } from "@/lib/simpleIconPath";

interface Props {
  platforms: string[];
  size?: "sm" | "md";
}

const { platforms, size = "sm" } = Astro.props;
const allPlatforms = await getAllPlatforms();
const platformMap = new Map(allPlatforms.map((p) => [p.id, p]));

const sizeClasses = {
  sm: "px-1.5 py-0.5 text-[10px]",
  md: "px-2 py-0.5 text-xs",
};
const iconSizeClasses = {
  sm: "h-2.5 w-2.5 shrink-0",
  md: "h-3 w-3 shrink-0",
};

// Map platform ID → Simple Icons slug
const simpleIconSlug: Record<string, string> = {
  ps1: "playstation",
  ps2: "playstation2",
  ps3: "playstation3",
  ps4: "playstation4",
  ps5: "playstation5",
  macos: "apple",
  ios: "ios",
  android: "android",
  linux: "linux",
  pc: "steam",
  "sega-genesis": "sega",
  "sega-saturn": "sega",
  "sega-dreamcast": "sega",
  "game-gear": "sega",
  "meta-quest": "meta",
  "htc-vive": "htcvive",
};

// Custom paths for platforms not in Simple Icons
const nintendoN = "M14.176 0H9.824C4.4 0 0 4.4 0 9.824v4.352C0 19.6 4.4 24 9.824 24h4.352C19.6 24 24 19.6 24 14.176V9.824C24 4.4 19.6 0 14.176 0zm-4.99 5.632h1.814l4.328 7.814V5.632h1.862v12.736H15.39l-4.34-7.842v7.842H9.186V5.632z";
const xboxSphere = "M5.082 4.534a9.651 9.651 0 0 1 13.836 0c-1.444-1.073-3.96-1.4-5.919.35l-1 .874-1-.874c-1.96-1.75-4.474-1.423-5.918-.35zm11.83 1.01c-.8-.75-2.37-1.61-3.75-.87.12.083.215.169.288.247.072.077.119.149.16.21.064.094.096.177.1.184.38.671.596 1.367.633 2.053a6.46 6.46 0 0 1-.2 1.945 10.625 10.625 0 0 1-.5 1.553l-.004.012c-.39.975-.86 1.946-1.384 2.85a18.92 18.92 0 0 1-1.252 1.87l.997 1.055a7.2 7.2 0 0 0 5.912-11.109zm-9.624-.87c-1.38-.74-2.95.12-3.75.87a7.2 7.2 0 0 0 5.912 11.11l.997-1.056a18.882 18.882 0 0 1-1.252-1.872c-.524-.903-.994-1.874-1.384-2.849l-.004-.012a10.643 10.643 0 0 1-.5-1.553 6.464 6.464 0 0 1-.199-1.945c.037-.686.253-1.382.633-2.053.004-.007.036-.09.1-.184.041-.061.088-.133.16-.21a1.63 1.63 0 0 1 .288-.247z";
const vrHeadset = "M21 7H3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3.27a2 2 0 0 0 1.6-.8L9 15h6l1.13 1.2a2 2 0 0 0 1.6.8H21a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM9 12a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm6 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4z";

const customPaths: Record<string, string> = {
  xbox: xboxSphere,
  "xbox-360": xboxSphere,
  "xbox-one": xboxSphere,
  "xbox-series-xs": xboxSphere,
  switch: nintendoN,
  "switch-2": nintendoN,
  n64: nintendoN,
  snes: nintendoN,
  nes: nintendoN,
  gamecube: nintendoN,
  wii: nintendoN,
  "wii-u": nintendoN,
  "game-boy": nintendoN,
  "game-boy-advance": nintendoN,
  "3ds": nintendoN,
  ds: nintendoN,
  vr: vrHeadset,
  pico: vrHeadset,
};

function getIconPath(id: string): string | null {
  const slug = simpleIconSlug[id];
  if (slug) {
    const path = simpleIconPath(slug);
    if (path) return path;
  }
  return customPaths[id] ?? null;
}
---

{platforms.length > 0 && (
  <div class="flex flex-wrap gap-1">
    {platforms.map((id) => {
      const platform = platformMap.get(id);
      const iconPath = getIconPath(id);
      return (
        <span
          class:list={[
            "inline-flex items-center gap-1 rounded-md bg-secondary text-secondary-foreground font-medium",
            sizeClasses[size],
          ]}
          title={platform?.description ?? id}
        >
          {iconPath ? (
            <svg
              class={iconSizeClasses[size]}
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              set:html={`<path d="${iconPath}"/>`}
            />
          ) : (
            <svg
              class={iconSizeClasses[size]}
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="7" width="20" height="14" rx="2" />
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
            </svg>
          )}
          {platform?.name ?? id}
        </span>
      );
    })}
  </div>
)}
