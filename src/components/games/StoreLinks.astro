---
import { buildStoreUrl, buildPlayUrl, buildPhysicalStoreUrl } from "@/lib/constants";
import { simpleIconPath } from "@/lib/simpleIconPath";

interface Props {
  stores: Record<string, string>;
  type: "buy" | "play" | "physical";
}

const { stores, type } = Astro.props;
const entries = Object.entries(stores);

const storeLabels: Record<string, string> = {
  steam: "Steam",
  epic: "Epic Games",
  gog: "GOG",
  humble: "Humble",
  psn: "PlayStation",
  xbox: "Xbox",
  nintendo_eshop: "Nintendo eShop",
  itch: "itch.io",
  green_man_gaming: "Green Man Gaming",
  app_store: "App Store",
  play_store: "Google Play",
  amazon_appstore: "Amazon Appstore",
  samsung_galaxy: "Galaxy Store",
  indiegala: "IndieGala",
  game_jolt: "Game Jolt",
  gameclub: "GameClub",
  poki: "Poki",
  crazygames: "CrazyGames",
  addicting_games: "Addicting Games",
  newgrounds: "Newgrounds",
  kongregate: "Kongregate",
  armor_games: "Armor Games",
  web: "Play Online",
  amazon: "Amazon",
  amazon_uk: "Amazon (UK)",
  amazon_us: "Amazon (US)",
  game_uk: "GAME",
  shopto: "ShopTo",
  website: "Official Site",
};

// Map store key → Simple Icons slug (filename without .svg)
const simpleIconSlug: Record<string, string> = {
  steam: "steam",
  epic: "epicgames",
  gog: "gogdotcom",
  humble: "humblebundle",
  psn: "playstation",
  itch: "itchdotio",
  app_store: "appstore",
  play_store: "googleplay",
  amazon_appstore: "amazon",
  samsung_galaxy: "samsung",
  newgrounds: "newgrounds",
  game_jolt: "gamejolt",
  kongregate: "kongregate",
};

// Xbox: proper brand sphere logo (Material Design Icons mdi:xbox)
const xboxPath = "M6.43 3.72c.07-.06.14-.12.19-.16C8.18 2.55 10 2 12 2c1.88 0 3.64.5 5.14 1.42c.11.08.4.27.56.46C16.25 2.28 12 5.7 12 5.7c-1.5-1.13-2.83-1.9-3.84-2.2c-.85-.21-1.43 0-1.7.2m12.88 1.51c-.05-.05-.1-.1-.14-.15c-.36-.4-.82-.5-1.2-.47c-.39.12-2.1.73-4.2 2.72c0 0 2.37 2.3 3.82 4.65s2.31 4.2 1.78 6.77C21 16.95 22 14.59 22 12c0-2.62-1-5-2.66-6.79m-3.61 7.75c-.65-.72-1.6-1.75-2.87-3.01c-.27-.27-.56-.55-.86-.85c0 0-.47.46-1.07 1.07c-.77.77-1.76 1.78-2.32 2.37c-.98 1.05-3.8 4.35-3.96 6.2c0 0-.65-1.46.75-4.85c.9-2.21 3.6-5.53 4.75-6.61c0 0-1.03-1.14-2.33-1.93l-.05-.03c-.63-.37-1.31-.66-1.97-.7c-.67.05-1.09.54-1.09.54A9.95 9.95 0 0 0 2 12a10 10 0 0 0 10 10c2.93 0 5.57-1.26 7.4-3.27c0 0-.21-1.33-1.56-3.23c-.31-.43-1.47-1.81-2.11-2.54";

// Nintendo N-in-rounded-rectangle
const nintendoPath = "M14.176 0H9.824C4.4 0 0 4.4 0 9.824v4.352C0 19.6 4.4 24 9.824 24h4.352C19.6 24 24 19.6 24 14.176V9.824C24 4.4 19.6 0 14.176 0zm-4.99 5.632h1.814l4.328 7.814V5.632h1.862v12.736H15.39l-4.34-7.842v7.842H9.186V5.632z";

// Amazon smile
const amazonPath = "M13.958 10.09c0 1.232.029 2.256-.591 3.351-.502.891-1.301 1.438-2.186 1.438-1.214 0-1.922-.924-1.922-2.292 0-2.692 2.415-3.182 4.7-3.182zm3.186 7.705a.66.66 0 0 1-.748.074c-1.051-.873-1.239-1.276-1.815-2.112-1.732 1.767-2.958 2.295-5.204 2.295-2.657 0-4.73-1.64-4.73-4.924 0-2.565 1.391-4.309 3.37-5.164 1.715-.754 4.11-.891 5.944-1.101v-.41c0-.753.059-1.642-.383-2.294-.385-.579-1.124-.819-1.775-.819-1.205 0-2.277.618-2.54 1.897-.054.285-.261.567-.549.582l-3.076-.333c-.259-.058-.548-.266-.472-.661C5.551 2.318 8.337.603 11.266.019 12.756.019 14.695.49 15.832 1.56c1.479 1.382 1.339 3.228 1.339 5.237v4.737c0 1.425.591 2.05 1.146 2.816.194.272.238.599-.01.8-.619.517-1.724 1.48-2.333 1.979zm4.393 2.912c-3.916 2.204-8.487 3.293-12.807 3.293-5.5 0-11.1-2.036-15.524-5.408-.322-.231-.057-.578.316-.386 4.443 2.582 9.924 4.14 15.562 4.14 3.807 0 7.99-.79 11.843-2.43.582-.241 1.069.385.61.791z";

// Icons that need raw SVG inner HTML rather than a single <path d="..."/>
const customHtml: Record<string, string> = {};

const customPaths: Record<string, string> = {
  xbox: xboxPath,
  nintendo_eshop: nintendoPath,
  amazon: amazonPath,
  amazon_appstore: amazonPath,
  green_man_gaming: "M7 11H5a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-2V9H7v2zm3-2h4V7h-4v2zm3 4h-2v-1h1v-1h1v2zm4 0h-1v-1h-1v1h-1v-2h3v2z",
  game_uk: "M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0",
  shopto: "M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0",
  indiegala: "M17 8C8 10 5.9 16.17 3.82 19.5c.95-3.06 2.98-5.83 4.68-7.17C7.17 14 4.83 15 3 17c2-6 8-10 14-9z",
  poki: "M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-1.5 6h3c2.485 0 4.5 2.015 4.5 4.5S15.985 15 13.5 15H10.5v3h-3V6h3zm0 3v3h3a1.5 1.5 0 0 0 0-3h-3z",
  crazygames: "M13 2L4.5 13.5H11L9 22l10.5-11.5H13L13 2z",
  addicting_games: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM9 16.5v-9l7 4.5-7 4.5z",
  armor_games: "M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z",
};

// Icons whose sub-paths require evenodd to render correctly
const evenOddStores = new Set(["nintendo_eshop"]);

// Resolve icon path: try Simple Icons SVG file first, then custom fallback
function getIconPath(store: string): string | null {
  const slug = simpleIconSlug[store];
  if (slug) {
    const path = simpleIconPath(slug);
    if (path) return path;
  }
  return customPaths[store] ?? null;
}

function getIconHtml(store: string): string | null {
  return customHtml[store] ?? null;
}

function getUrl(store: string, id: string): string {
  if (type === "buy") return buildStoreUrl(store, id);
  if (type === "play") return buildPlayUrl(store, id);
  return buildPhysicalStoreUrl(store, id);
}
---

{entries.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {entries.map(([store, id]) => {
      const iconHtml = getIconHtml(store);
      const iconPath = getIconPath(store);
      return (
        <a
          href={getUrl(store, id)}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          {iconHtml ? (
            <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={iconHtml} />
          ) : iconPath ? (
            <svg
              class="h-4 w-4 shrink-0 text-muted-foreground"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              set:html={`<path ${evenOddStores.has(store) ? 'fill-rule="evenodd" ' : ""}d="${iconPath}"/>`}
            />
          ) : (
            <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          )}
          {storeLabels[store] ?? store}
        </a>
      );
    })}
  </div>
)}
