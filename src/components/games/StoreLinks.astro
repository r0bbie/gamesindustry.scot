const simpleIconSlug: Record<string, string> = {
  steam: "steam",
  epic: "epicgames",
  gog: "gogdotcom",
  humble: "humblebundle",
  psn: "playstation",
  itch: "itchdotio",
  app_store: "appstore",
  play_store: "googleplay",
