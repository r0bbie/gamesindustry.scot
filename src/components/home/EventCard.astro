---
import type { Event } from "@/lib/data";
import { EVENT_TAGS } from "@/lib/constants";

interface Props {
  event: Event;
}

const { event } = Astro.props;

const startDate = new Date(event.date_start).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});

const displayLocation = event.is_online ? "Online" : (event.location ?? "TBC");

function getTagName(tagId: string): string {
  return EVENT_TAGS.find((t) => t.id === tagId)?.name ?? tagId;
}
---

<a
  href={`/events/${event.slug}`}
  class="group rounded-xl border border-border bg-card text-card-foreground shadow transition-colors hover:border-primary/30 hover:shadow-md"
>
  <div class="flex flex-col p-5">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-semibold leading-tight tracking-tight group-hover:text-primary transition-colors line-clamp-2">
        {event.name}
      </h3>
      {event.is_scottish && (
        <span class="shrink-0 text-base" title="Scottish event">🏴󠁧󠁢󠁳󠁣󠁴󠁿</span>
      )}
    </div>

    <div class="mt-2 flex items-center gap-1.5 text-sm text-muted-foreground">
      <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 2v4" /><path d="M16 2v4" />
        <rect width="18" height="18" x="3" y="4" rx="2" />
        <path d="M3 10h18" />
      </svg>
      {startDate}
    </div>

    <div class="mt-1 flex items-center gap-1.5 text-sm text-muted-foreground">
      <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      {displayLocation}
    </div>

    {event.tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {event.tags.map((tag) => (
          <span class="inline-flex items-center rounded-md border border-transparent bg-secondary px-2 py-0.5 text-xs font-medium text-secondary-foreground">
            {getTagName(tag)}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
