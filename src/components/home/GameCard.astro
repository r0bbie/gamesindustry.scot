---
import type { Game } from "@/lib/data";

interface Props {
  game: Game;
  developerName: string;
}

const { game, developerName } = Astro.props;

const releaseDate = game.release_date
  ? new Date(game.release_date).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
  : null;
---

<a
  href={`/games/${game.slug}`}
  class="group rounded-xl border border-border bg-card text-card-foreground shadow transition-colors hover:border-primary/30 hover:shadow-md overflow-hidden"
>
  <!-- Cover image or placeholder -->
  <div class="aspect-[16/9] w-full bg-gradient-to-br from-primary/20 via-primary/10 to-muted overflow-hidden">
    {game.cover_image ? (
      <img src={game.cover_image} alt={game.title} class="h-full w-full object-cover transition-transform group-hover:scale-105" />
    ) : (
      <div class="flex h-full w-full items-center justify-center">
        <svg class="h-10 w-10 text-muted-foreground/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" x2="10" y1="11" y2="11" /><line x1="8" x2="8" y1="9" y2="13" />
          <line x1="15" x2="15.01" y1="12" y2="12" /><line x1="18" x2="18.01" y1="10" y2="10" />
          <path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1.11 0 2.08-.402 2.592-1.382l.375-.646a1 1 0 0 1 .866-.498h6.334a1 1 0 0 1 .866.498l.375.646C16.92 18.598 17.89 19 19 19a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.152A4 4 0 0 0 17.32 5z" />
        </svg>
      </div>
    )}
  </div>

  <div class="p-4">
    <h3 class="font-semibold leading-tight tracking-tight group-hover:text-primary transition-colors line-clamp-1">
      {game.title}
    </h3>
    <p class="mt-1 text-sm text-muted-foreground line-clamp-1">{developerName}</p>
    {releaseDate && (
      <p class="mt-1.5 text-xs text-muted-foreground">{releaseDate}</p>
    )}
  </div>
</a>
