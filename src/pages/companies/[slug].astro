---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllCompanies,
  getChildCompanies,
  getCompanyBySlug,
  getGamesForCompany,
  getJobsForCompany,
  getNewsForCompany,
  safeGetCompany,
  resolveCompanyIds,
  resolveToolIds,
  getToolsForCompany,
  matchesCompanyRef,
} from "@/lib/data";
import {
  getCategoryName,
  getCategorySingularName,
  getRegionName,
  buildSocialUrl,
  getCompanySizeLabel,
  getCompanySizeEntry,
  getAwardStatusLabel,
  getDisciplineName,
  GITHUB_REPO,
} from "@/lib/constants";
import { Badge } from "@/components/ui/badge";
import { BrokenLink } from "@/components/ui/broken-link";
import GameCoverImage from "@/components/games/GameCoverImage";
import ObfuscatedEmail from "@/components/ObfuscatedEmail.astro";
import { buildObfuscatedMailtoAnchorHtml } from "@/lib/obfuscateEmail";
import {
  formatGameReleaseLineDisplay,
  getLatestReleaseSortTimestamp,
  getFirstReleaseSortTimestamp,
} from "@/lib/gameRelease";

function getCoverGradient(title: string): string {
  const hue = [...title].reduce((sum, ch) => sum + ch.charCodeAt(0), 0) % 360;
  return `linear-gradient(135deg, hsl(${hue}, 55%, 38%), hsl(${(hue + 45) % 360}, 45%, 28%))`;
}

export async function getStaticPaths() {
  const companies = await getAllCompanies();
  return companies.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const company = await getCompanyBySlug(slug!);
if (!company) return Astro.redirect("/404");

const games = await getGamesForCompany(company.id);
const jobs = await getJobsForCompany(company.id);
const categories = company.categories;

// Resolve parent entity
let parentCompany: Awaited<ReturnType<typeof safeGetCompany>> = null;
if (company.parent_entity?.company_id) {
  parentCompany = await safeGetCompany(
    company.parent_entity.company_id,
    `company-${company.id}`
  );
}

const childCompanies = await getChildCompanies(company.id);

// Resolve use_tooling → tool records
const toolingRefs = await resolveToolIds(
  company.use_tooling,
  `company-${company.id}`
);

// Tools this company makes (shown in "Tools" tab for tooling companies)
const companyTools = categories.includes("tooling")
  ? await getToolsForCompany(company.id)
  : [];

// Games grouped by relationship
const devGames = games.filter((g) =>
  matchesCompanyRef(g.companies.developer, company.id)
);
const serviceGames = games.filter((g) =>
  matchesCompanyRef(g.companies.service_companies, company.id)
);
const publishedGames = games.filter((g) =>
  matchesCompanyRef(g.companies.publishers, company.id)
);
const supportedGames = games.filter((g) =>
  matchesCompanyRef(g.companies.supported_by, company.id)
);

const contributedGames = games.filter((g) =>
  matchesCompanyRef(g.companies.contributed_by, company.id)
);

const inDevGames = devGames.filter((g) => g.status === "in_development");
const releasedGames = devGames
  .filter((g) => g.status === "released")
  .sort(
    (a, b) => getFirstReleaseSortTimestamp(b) - getFirstReleaseSortTimestamp(a),
  );
const cancelledGames = devGames.filter((g) => g.status === "cancelled");
const prototypeGames = devGames.filter((g) => g.status === "prototype");

// Tab configuration
interface Tab {
  id: string;
  label: string;
}

const hasEmployeeStats =
  company.employee_stats &&
  (company.employee_stats.full_time != null ||
    company.employee_stats.gender_split != null);
const hasTeamData = company.key_people.length > 0 || hasEmployeeStats;

const tabs: Tab[] = [{ id: "overview", label: "Overview" }];

const nonPrototypeGames = games.filter((g) => g.status !== "prototype");
const hasCategory = (...cats: string[]) => cats.some((c) => categories.includes(c));

const showGamesTab =
  hasCategory("developer", "solo_developer", "service_provider", "publisher", "supporting_org") &&
  (nonPrototypeGames.length > 0 || prototypeGames.length > 0);
if (showGamesTab) tabs.push({ id: "games", label: "Games" });

const showToolsTab =
  (categories.includes("tooling") && companyTools.length > 0) ||
  company.use_tooling.length > 0 ||
  company.tech_stack.length > 0;
// Tooling companies get the tab right after Games; everyone else gets it last
if (showToolsTab && categories.includes("tooling")) tabs.push({ id: "tools", label: "Tools" });

const showJobsTab =
  hasCategory("developer", "solo_developer", "tooling", "service_provider", "publisher", "games_media") &&
  jobs.length > 0;
if (showJobsTab) tabs.push({ id: "jobs", label: "Jobs" });

const showTeamTab =
  hasCategory("developer", "solo_developer", "tooling", "service_provider", "publisher", "games_media") &&
  hasTeamData;
if (showTeamTab) tabs.push({ id: "team", label: "Team" });

const showAwardsTab =
  hasCategory("developer", "solo_developer", "service_provider") &&
  company.awards.length > 0;
if (showAwardsTab) tabs.push({ id: "awards", label: "Awards" });

const companyNews = await getNewsForCompany(company.id);

const showNewsTab =
  hasCategory(
    "developer",
    "solo_developer",
    "tooling",
    "service_provider",
    "publisher",
    "supporting_org",
    "games_media",
  ) &&
  companyNews.length > 0;
if (showNewsTab) tabs.push({ id: "news", label: "News" });
if (showToolsTab && !categories.includes("tooling")) tabs.push({ id: "tools", label: "Tools" });

// Social links
function formatPlatformName(platform: string): string {
  const names: Record<string, string> = {
    twitter: "Twitter / X",
    bluesky: "Bluesky",
    mastodon: "Mastodon",
    linkedin: "LinkedIn",
    steam: "Steam",
    twitch: "Twitch",
    discord: "Discord",
    youtube: "YouTube",
    github: "GitHub",
    instagram: "Instagram",
    app_store: "App Store",
    google_play: "Google Play",
    threads: "Threads",
    behance: "Behance",
    dribbble: "Dribbble",
    artstation: "ArtStation",
    gumroad: "Gumroad",
    soundcloud: "SoundCloud",
    bandcamp: "Bandcamp",
    itch: "itch.io",
  };
  return (
    names[platform] ??
    platform.charAt(0).toUpperCase() + platform.slice(1).replace(/_/g, " ")
  );
}

const socialLinks = Object.entries(company.links ?? {}).map(
  ([platform, handle]) => ({
    platform,
    label: formatPlatformName(platform),
    url: buildSocialUrl(platform, handle),
  })
);

const editUrl = `https://github.com/${GITHUB_REPO}/edit/main/data/companies/${company.id}.json`;

function formatGameDate(dateStr?: string): string {
  if (!dateStr) return "";
  // Year only: "1994"
  if (/^\d{4}$/.test(dateStr)) return dateStr;
  // Year + month: "1994-11"
  if (/^\d{4}-\d{2}$/.test(dateStr)) {
    const [year, month] = dateStr.split("-");
    return new Date(Number(year), Number(month) - 1).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
    });
  }
  // Full date: "1994-11-25"
  return new Date(dateStr).toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const recentGames = [...devGames]
  .filter((g) => g.status === "released")
  .sort(
    (a, b) =>
      getFirstReleaseSortTimestamp(b) - getFirstReleaseSortTimestamp(a),
  )
  .slice(0, 3);
const recentNews = companyNews.slice(0, 5);
---

<BaseLayout title={company.name}>
  <!-- Hero -->
  <section class="border-b border-border bg-card">
    <div
      class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8"
    >
      <div
        class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between"
      >
        <div class="flex items-start gap-4">
          <div
            class={`flex h-16 w-16 shrink-0 items-center justify-center rounded-xl ${company.logo_bg === "light" ? "bg-white" : company.logo_bg === "dark" ? "bg-zinc-900" : "bg-muted"}`}
          >
            {(company.icon ?? company.logo) ? (
              <img
                src={company.icon ?? company.logo!}
                alt={`${company.name} logo`}
                class={company.logo_bg ? "h-full w-full rounded-xl object-contain" : "h-12 w-12 object-contain"}
              />
            ) : (
              <span class="text-2xl font-bold text-muted-foreground">{company.name.charAt(0)}</span>
            )}
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="text-3xl font-bold tracking-tight">
                {company.name}
              </h1>
              {categories.map((cat) => (
                <Badge variant="secondary">{getCategorySingularName(cat)}</Badge>
              ))}
              {
                company.status === "defunct" && (
                  <Badge variant="outline">Defunct</Badge>
                )
              }
            </div>
            {
              company.location && (
                <p class="mt-1 text-muted-foreground">{company.location}</p>
              )
            }
            {
              company.short_description && (
                <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
                  {company.short_description}
                </p>
              )
            }
          </div>
        </div>

        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 shrink-0 items-center gap-2 rounded-md border border-input bg-background px-3 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
            ></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
            ></path>
          </svg>
          Suggest a change
        </a>
      </div>

      {
        socialLinks.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {socialLinks.map(({ platform, label, url }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1 text-xs font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
              >
                {platform === "twitter" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>}
