---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllCompanies,
  getCompanyBySlug,
  getGamesForCompany,
  getJobsForCompany,
  getNewsForCompany,
  safeGetCompany,
  resolveCompanyIds,
} from "@/lib/data";
import {
  getCategoryName,
  getRegionName,
  buildSocialUrl,
  GITHUB_REPO,
} from "@/lib/constants";
import { Badge } from "@/components/ui/badge";
import { BrokenLink } from "@/components/ui/broken-link";

export async function getStaticPaths() {
  const companies = await getAllCompanies();
  return companies.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const company = await getCompanyBySlug(slug!);
if (!company) return Astro.redirect("/404");

const games = await getGamesForCompany(company.id);
const jobs = await getJobsForCompany(company.id);
const category = company.category;

// Resolve parent entity
let parentCompany: Awaited<ReturnType<typeof safeGetCompany>> = null;
if (company.parent_entity?.company_id) {
  parentCompany = await safeGetCompany(
    company.parent_entity.company_id,
    `company-${company.id}`
  );
}

// Resolve use_tooling
const toolingRefs = await resolveCompanyIds(
  company.use_tooling,
  `company-${company.id}`
);

// For tooling companies: find who uses this tool
const allCompanies = await getAllCompanies();
const usedByCompanies =
  category === "tooling"
    ? allCompanies.filter((c) => c.use_tooling.includes(company.id))
    : [];

// Games grouped by relationship
const devGames = games.filter((g) =>
  g.companies.developer.includes(company.id)
);
const serviceGames = games.filter((g) =>
  g.companies.service_companies.includes(company.id)
);
const publishedGames = games.filter((g) =>
  g.companies.publishers.includes(company.id)
);
const supportedGames = games.filter((g) =>
  g.companies.supported_by.includes(company.id)
);

const inDevGames = devGames.filter((g) => g.status === "in_development");
const releasedGames = devGames.filter((g) => g.status === "released");
const cancelledGames = devGames.filter((g) => g.status === "cancelled");

// Tab configuration
interface Tab {
  id: string;
  label: string;
}

const hasEmployeeStats =
  company.employee_stats &&
  (company.employee_stats.full_time != null ||
    company.employee_stats.gender_split != null);
const hasTeamData = company.key_people.length > 0 || hasEmployeeStats;

const tabs: Tab[] = [{ id: "overview", label: "Overview" }];

const showGamesTab =
  ["developer", "solo_developer", "service_provider", "publisher", "supporting_org"].includes(
    category
  ) && games.length > 0;
if (showGamesTab) tabs.push({ id: "games", label: "Games" });

if (category === "tooling") tabs.push({ id: "used-by", label: "Used By" });

const showJobsTab =
  ["developer", "solo_developer", "tooling", "service_provider", "publisher", "games_media"].includes(
    category
  ) && jobs.length > 0;
if (showJobsTab) tabs.push({ id: "jobs", label: "Jobs" });

const showTeamTab =
  ["developer", "solo_developer", "tooling", "service_provider", "publisher", "games_media"].includes(
    category
  ) && hasTeamData;
if (showTeamTab) tabs.push({ id: "team", label: "Team" });

const showAwardsTab =
  ["developer", "solo_developer", "service_provider"].includes(category) &&
  company.awards.length > 0;
if (showAwardsTab) tabs.push({ id: "awards", label: "Awards" });

const companyNews = await getNewsForCompany(company.id);

const showNewsTab =
  ["developer", "solo_developer", "tooling", "service_provider", "games_media"].includes(
    category
  ) && companyNews.length > 0;
if (showNewsTab) tabs.push({ id: "news", label: "News" });

// Social links
function formatPlatformName(platform: string): string {
  const names: Record<string, string> = {
    twitter: "Twitter / X",
    bluesky: "Bluesky",
    mastodon: "Mastodon",
    linkedin: "LinkedIn",
    steam: "Steam",
    twitch: "Twitch",
    discord: "Discord",
    youtube: "YouTube",
    github: "GitHub",
    instagram: "Instagram",
    app_store: "App Store",
    google_play: "Google Play",
    behance: "Behance",
    dribbble: "Dribbble",
    artstation: "ArtStation",
    gumroad: "Gumroad",
    soundcloud: "SoundCloud",
    bandcamp: "Bandcamp",
  };
  return (
    names[platform] ??
    platform.charAt(0).toUpperCase() + platform.slice(1).replace(/_/g, " ")
  );
}

const socialLinks = Object.entries(company.links ?? {}).map(
  ([platform, handle]) => ({
    platform,
    label: formatPlatformName(platform),
    url: buildSocialUrl(platform, handle),
  })
);

const editUrl = `https://github.com/${GITHUB_REPO}/edit/main/data/companies/${company.id}.json`;

const recentGames = games.slice(0, 3);
const recentNews = companyNews.slice(0, 5);
---

<BaseLayout title={company.name}>
  <!-- Hero -->
  <section class="border-b border-border bg-card">
    <div
      class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8"
    >
      <div
        class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between"
      >
        <div class="flex items-start gap-4">
          <div
            class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl bg-muted"
          >
            {company.logo ? (
              <img
                src={company.logo}
                alt={`${company.name} logo`}
                class="h-12 w-12 object-contain"
              />
            ) : (
              <span class="text-2xl font-bold text-muted-foreground">{company.name.charAt(0)}</span>
            )}
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="text-3xl font-bold tracking-tight">
                {company.name}
              </h1>
              <Badge variant="secondary">{getCategoryName(category)}</Badge>
              {
                company.status === "defunct" && (
                  <Badge variant="outline">Defunct</Badge>
                )
              }
            </div>
            {
              company.location && (
                <p class="mt-1 text-muted-foreground">{company.location}</p>
              )
            }
            {
              company.short_description && (
                <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
                  {company.short_description}
                </p>
              )
            }
          </div>
        </div>

        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 shrink-0 items-center gap-2 rounded-md border border-input bg-background px-3 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
            ></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
            ></path>
          </svg>
          Suggest a change
        </a>
      </div>

      {
        socialLinks.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {socialLinks.map(({ platform, label, url }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1 text-xs font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
              >
                {platform === "twitter" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>}
                {platform === "bluesky" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.476 6.158 3.239-4.43.418-8.316 1.862-2.792 6.514 5.657 4.766 7.752-1.196 8.01-2.275.258 1.079 2.353 7.041 8.01 2.275 5.524-4.652 1.639-6.096-2.792-6.514 2.558.237 5.373-.612 6.158-3.239C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.861-.902-2.203-.659-.3-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>}
                {platform === "mastodon" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.547c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.636.536c.562 0 1.124-.016 1.685-.05 2.126-.118 4.4-.355 6.395-1.368a6.394 6.394 0 0 0 2.654-3.44c.436-1.39.665-2.855.665-4.343 0-.199-.01-.66-.01-.66l-.005-.017zM19.262 13.396h-2.66V8.031c0-1.13-.477-1.703-1.427-1.703-1.052 0-1.579.68-1.579 2.024v2.947h-2.643V8.352c0-1.345-.527-2.024-1.58-2.024-.949 0-1.426.574-1.426 1.703v5.365H5.29V7.836c0-1.13.288-2.029.868-2.692.598-.664 1.38-.998 2.35-.998 1.123 0 1.972.431 2.536 1.292l.547.916.547-.916c.564-.861 1.413-1.292 2.536-1.292.97 0 1.752.334 2.35.998.58.663.868 1.562.868 2.692v5.56z"/></svg>}
                {platform === "linkedin" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>}
                {platform === "steam" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.029 4.524 4.524s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.492 1.009 2.447-.397.957-1.497 1.41-2.455 1.02zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/></svg>}
                {platform === "twitch" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>}
                {platform === "discord" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.04.032.05a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>}
                {platform === "youtube" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>}
                {platform === "github" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>}
                {platform === "instagram" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>}
                {platform === "app_store" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M8.809 0c-.48.002-1.501.157-2.57 1.223L4.224 3.24h3.34L8.81 0zm6.38 0l1.254 3.24h3.338l-2.01-2.018C16.706.157 15.684.002 15.19 0h-.002zM0 4.512v2.4h24v-2.4H0zm1.524 3.676L4.67 20.28C5.21 22.528 6.647 24 9.03 24h5.94c2.383 0 3.82-1.472 4.36-3.72l3.147-12.092H1.524zm10.363 1.96c.356 0 .716.129.993.39l1.258 1.186 1.258-1.186a1.368 1.368 0 0 1 1.855.044 1.269 1.269 0 0 1-.044 1.807l-1.218 1.147 2.967 2.797a1.27 1.27 0 0 1 .044 1.808 1.368 1.368 0 0 1-1.855.043l-3.006-2.834-3.006 2.834a1.368 1.368 0 0 1-1.855-.043 1.27 1.27 0 0 1 .044-1.808l2.967-2.797-1.218-1.147a1.269 1.269 0 0 1-.044-1.807c.264-.273.62-.435.86-.435z"/></svg>}
                {platform === "google_play" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M22.018 13.298l-3.919 2.218-3.515-3.493 3.543-3.521 3.891 2.202a1.49 1.49 0 0 1 0 2.594zM1.337.924a1.486 1.486 0 0 0-.112.568v21.017c0 .217.045.419.124.6l11.155-11.087L1.337.924zm11.908 10.817l-1.032 1.026L1.079 23.075a1.49 1.49 0 0 0 .698-.204l13.553-7.673-2.085-2.457zm0-2.285l2.088-2.074L3.064.45a1.493 1.493 0 0 0-.768-.208l11.95 9.214z"/></svg>}
                {!["twitter","bluesky","mastodon","linkedin","steam","twitch","discord","youtube","github","instagram","app_store","google_play"].includes(platform) && (
                  <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                )}
                {label}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Sticky Tab Bar -->
  <nav
    id="company-tabs"
    class="sticky top-14 z-40 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="-mb-px flex gap-0 overflow-x-auto">
        {
          tabs.map((tab, i) => (
            <button
              type="button"
              data-tab-btn={tab.id}
              class:list={[
                "whitespace-nowrap border-b-2 px-4 py-3 text-sm font-medium transition-colors",
                i === 0
                  ? "border-primary text-foreground"
                  : "border-transparent text-muted-foreground hover:border-primary/50 hover:text-foreground",
              ]}
            >
              {tab.label}
            </button>
          ))
        }
      </div>
    </div>
  </nav>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Overview -->
    <section id="overview" data-tab-panel="overview">
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="space-y-8 lg:col-span-2">
          {
            company.about && (
              <div>
                <h2 class="mb-3 text-xl font-semibold">About</h2>
                <p class="whitespace-pre-line leading-relaxed text-muted-foreground">
                  {company.about}
                </p>
              </div>
            )
          }

          {
            recentGames.length > 0 && (
              <div>
                <h3 class="mb-3 text-lg font-semibold">Recent Games</h3>
                <div class="grid gap-3 sm:grid-cols-3">
                  {recentGames.map((game) => (
                    <a
