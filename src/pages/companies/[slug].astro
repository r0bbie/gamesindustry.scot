                            </a>
                          )}
                          {person.mastodon && (
                            <a href={person.mastodon} target="_blank" rel="noopener noreferrer" title="Mastodon" class="text-muted-foreground hover:text-foreground transition-colors">
                              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.547c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.636.536c.562 0 1.124-.016 1.685-.05 2.126-.118 4.4-.355 6.395-1.368a6.394 6.394 0 0 0 2.654-3.44c.436-1.39.665-2.855.665-4.343 0-.199-.01-.66-.01-.66l-.005-.017zM19.262 13.396h-2.66V8.031c0-1.13-.477-1.703-1.427-1.703-1.052 0-1.579.68-1.579 2.024v2.947h-2.643V8.352c0-1.345-.527-2.024-1.58-2.024-.949 0-1.426.574-1.426 1.703v5.365H5.29V7.836c0-1.13.288-2.029.868-2.692.598-.664 1.38-.998 2.35-.998 1.123 0 1.972.431 2.536 1.292l.547.916.547-.916c.564-.861 1.413-1.292 2.536-1.292.97 0 1.752.334 2.35.998.58.663.868 1.562.868 2.692v5.56z"/></svg>
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </section>
      )
    }

    <!-- Awards Section -->
    {
      showAwardsTab && (
        <section id="awards" data-tab-panel="awards" class="hidden">
          <h2 class="mb-6 text-2xl font-semibold">Awards</h2>
          <div class="space-y-2">
            {company.awards.map((award) => (
              <div class="flex items-center justify-between rounded-lg border border-border bg-card p-3">
                <div class="flex items-center gap-3">
                  <span class="text-sm font-medium">{award.name}</span>
                  <span class="text-xs text-muted-foreground">
                    {award.year}
                  </span>
                </div>
                <Badge
                  variant={award.status === "won" ? "default" : "secondary"}
                >
                  {award.status === "won" ? "Won" : "Nominated"}
                </Badge>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- News Section -->
    {
      showNewsTab && (
        <section id="news" data-tab-panel="news" class="hidden">
          <h2 class="mb-6 text-2xl font-semibold">News</h2>
          <div class="space-y-2">
            {companyNews.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-start gap-3 rounded-lg border border-border bg-card p-3 transition-colors hover:bg-accent/50"
              >
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium">{item.title}</p>
                  <p class="mt-0.5 text-xs text-muted-foreground">
                    {item.publication} &middot; {item.date}
                  </p>
                </div>
                <svg
                  class="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                  />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('[data-tab-btn]');
    const panels = document.querySelectorAll('[data-tab-panel]');
    if (!btns.length) return;

    const firstTab = btns[0].dataset.tabBtn;

    function activate(id, pushState) {
      panels.forEach(p => {
        p.classList.toggle('hidden', p.dataset.tabPanel !== id);
      });
      btns.forEach(b => {
        const isActive = b.dataset.tabBtn === id;
        b.classList.toggle('border-primary', isActive);
        b.classList.toggle('text-foreground', isActive);
        b.classList.toggle('border-transparent', !isActive);
        b.classList.toggle('text-muted-foreground', !isActive);
      });
      if (pushState) {
        const url = new URL(window.location.href);
        if (id === firstTab) {
          url.hash = '';
        } else {
          url.hash = id;
        }
        history.pushState(null, '', url.toString());
      }
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => activate(btn.dataset.tabBtn, true));
    });

    // Activate from URL hash on load, falling back to first tab
    const hash = window.location.hash.slice(1);
    const validIds = Array.from(btns).map(b => b.dataset.tabBtn);
    activate(validIds.includes(hash) ? hash : firstTab, false);

    // Handle browser back/forward
    window.addEventListener('popstate', () => {
      const h = window.location.hash.slice(1);
      activate(validIds.includes(h) ? h : firstTab, false);
    });
  });
</script>
