                {platform === "app_store" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.5 135.4-317.3 269-317.3 70.1 0 128.4 46.4 172.5 46.4 42.8 0 109.6-49 192.5-49 30.9 0 133.9 2.6 198.3 99zM554.1 158.4c31.6-37.8 54.4-90.2 54.4-142.6 0-7.1-.6-14.3-1.9-20.1-51.9 1.9-113.3 34.9-150.5 78.4-28.3 32.8-55.8 85.2-55.8 138.2 0 7.7 1.3 15.5 1.9 17.9 3.2.6 8.4 1.3 13.6 1.3 46.4 0 104.5-31.6 138.3-73.1z"/></svg>}
                {platform === "google_play" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76a2.5 2.5 0 0 0 2.56-.18l12.59-7.32-2.88-2.9zM.5 1.1A2.47 2.47 0 0 0 0 2.62v18.76a2.47 2.47 0 0 0 .5 1.52L.62 23l10.51-10.51v-.26L.62 1.73zm19.7 9.93-2.97-1.73-3.19 3.2 3.19 3.2 2.98-1.73a2.51 2.51 0 0 0 0-4.94zM3.18.24 15.78 7.6l-2.88 2.89z"/></svg>}
                {platform === "threads" && <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.286.02 5.241 2.018 5.501 5.508a7.559 7.559 0 0 1 1.46.87c1.197.9 1.97 2.17 2.253 3.666.376 2.07-.07 4.664-2.111 6.667C17.857 23.537 15.617 24 12.186 24zm-2.21-9.091c.28 1.067 1.14 1.172 1.875 1.132 1.169-.063 1.888-.693 2.149-1.876a12.41 12.41 0 0 0-2.79-.175c-.909.052-1.415.398-1.233 1.002v-.083z"/></svg>}
                {!["twitter","bluesky","mastodon","linkedin","steam","twitch","discord","youtube","github","instagram","app_store","google_play","threads"].includes(platform) && (
                  <svg class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                )}
                {label}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Sticky Tab Bar -->
  <nav
    id="company-tabs"
    class="sticky top-14 z-40 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="-mb-px flex gap-0 overflow-x-auto">
        {
          tabs.map((tab, i) => (
            <button
              type="button"
              data-tab-btn={tab.id}
              class:list={[
                "whitespace-nowrap border-b-2 px-4 py-3 text-sm font-medium transition-colors",
                i === 0
                  ? "border-primary text-foreground"
                  : "border-transparent text-muted-foreground hover:border-primary/50 hover:text-foreground",
              ]}
            >
              {tab.label}
            </button>
          ))
        }
      </div>
    </div>
  </nav>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Overview -->
    <section id="overview" data-tab-panel="overview">
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="space-y-8 lg:col-span-2">
          {
            company.about && (
              <div>
                <h2 class="mb-3 text-xl font-semibold">About</h2>
                <p class="whitespace-pre-line leading-relaxed text-muted-foreground">
                  {company.about}
                </p>
              </div>
            )
          }

          {
            (recentGames.length > 0 || inDevGames.length > 0) && (
              <div class="space-y-6">
                {inDevGames.length > 0 && (
                  <div>
                    <h3 class="mb-3 text-lg font-semibold">In Development</h3>
                    <div class="grid gap-3 sm:grid-cols-3">
                      {inDevGames.map((game) => (
                        <a
                          href={`/games/${game.slug}`}
                          class="group rounded-lg border border-border bg-card p-3 transition-colors hover:border-primary/30"
                        >
                          <div class="relative mb-2 flex aspect-[2/3] items-center justify-center overflow-hidden rounded-md bg-muted">
                            {game.cover_image ? (
                              <GameCoverImage client:load src={game.cover_image} forceFill={game.cover_fill} />
                            ) : (
                              <span
                                class="flex h-full w-full items-center justify-center rounded-md text-4xl font-bold text-white/60 select-none"
                                style={`background: ${getCoverGradient(game.title)}`}
                              >{game.title.charAt(0)}</span>
                            )}
                          </div>
                          <h4 class="text-sm font-medium group-hover:text-primary">
                            {game.title}
                          </h4>
                          <p class="mt-0.5 text-xs text-muted-foreground">{formatGameReleaseLineDisplay(game)}</p>
                        </a>
                      ))}
                    </div>
                  </div>
                )}
                {recentGames.length > 0 && (
                  <div>
                    <div class="mb-3 flex items-center justify-between">
                      <h3 class="text-lg font-semibold">Recent Games</h3>
                      {releasedGames.length > 3 && (
                        <a href="#games" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                          View all {releasedGames.length} games →
                        </a>
                      )}
                    </div>
                    <div class="grid gap-3 sm:grid-cols-3">
                      {recentGames.map((game) => (
                        <a
                          href={`/games/${game.slug}`}
                          class="group rounded-lg border border-border bg-card p-3 transition-colors hover:border-primary/30"
                        >
                          <div class="relative mb-2 flex aspect-[2/3] items-center justify-center overflow-hidden rounded-md bg-muted">
                            {game.cover_image ? (
                              <GameCoverImage client:load src={game.cover_image} forceFill={game.cover_fill} />
                            ) : (
                              <span
                                class="flex h-full w-full items-center justify-center rounded-md text-4xl font-bold text-white/60 select-none"
                                style={`background: ${getCoverGradient(game.title)}`}
                              >{game.title.charAt(0)}</span>
                            )}
                          </div>
                          <h4 class="text-sm font-medium group-hover:text-primary">
                            {game.title}
                          </h4>
                          <p class="mt-0.5 text-xs text-muted-foreground">
                            {formatGameReleaseLineDisplay(game)}
                          </p>
                          {Object.keys(game.critic_ratings).length > 0 && (
                            <div class="mt-1">
                              {Object.entries(game.critic_ratings)
                                .slice(0, 1)
                                .map(([, score]) => (
                                  <span class="inline-flex items-center rounded bg-primary/10 px-1.5 py-0.5 text-[10px] font-semibold text-primary">
                                    {score}
                                  </span>
                                ))}
                            </div>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )
          }

          {
            recentNews.length > 0 && (
              <div>
                <h3 class="mb-3 text-lg font-semibold">Recent News</h3>
                <div class="space-y-2">
                  {recentNews.map((item) => (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-start gap-3 rounded-lg border border-border p-3 transition-colors hover:bg-accent/50"
                    >
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium">{item.title}</p>
                        <p class="mt-0.5 text-xs text-muted-foreground">
                          {item.publication} &middot; {item.date}
                        </p>
                      </div>
                      <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <!-- Sidebar -->
        <aside>
          <div class="rounded-xl border border-border bg-card p-5">
            <h3
              class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground"
            >
              Details
            </h3>
            <dl class="space-y-3">
              <div>
                <dt class="text-xs text-muted-foreground">Status</dt>
                <dd class="text-sm font-medium capitalize">
                  {company.status}
                </dd>
              </div>
              {
                company.founded && (
                  <div>
                    <dt class="text-xs text-muted-foreground">Founded</dt>
                    <dd class="text-sm font-medium">{company.founded}</dd>
                  </div>
                )
              }
              {
                company.previously_known_as.length > 0 && (
                  <div>
                    <dt class="text-xs text-muted-foreground">Previously Known As</dt>
                    <dd class="text-sm font-medium">{company.previously_known_as.join(', ')}</dd>
                  </div>
                )
              }
              {
                company.location && (
                  <div>
                    <dt class="text-xs text-muted-foreground">Location</dt>
                    <dd class="text-sm font-medium">
                      {company.location}
                      {company.region && (
                        <span class="text-muted-foreground">
                          {" "}
                          &middot; {getRegionName(company.region)}
                        </span>
                      )}
                    </dd>
                  </div>
                )
              }
              {
                company.additional_locations.length > 0 && (
                  <div>
                    <dt class="text-xs text-muted-foreground">Other locations</dt>
                    <dd class="text-sm font-medium">
                      {company.additional_locations.join(", ")}
                    </dd>
                  </div>
                )
              }
              {
                company.parent_entity && (
                  <div>
                    <dt class="text-xs text-muted-foreground">
                      Parent Entity
                    </dt>
                    <dd class="text-sm font-medium">
                      {company.parent_entity.company_id ? (
                        parentCompany ? (
                          <a
                            href={`/companies/${parentCompany.slug}`}
                            class="text-primary hover:underline"
                          >
                            {company.parent_entity.name}
                          </a>
                        ) : (
                          <BrokenLink
                            id={company.parent_entity.company_id}
                            type="company"
                          />
                        )
                      ) : company.parent_entity.url ? (
                        <a
                          href={company.parent_entity.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:underline"
                        >
                          {company.parent_entity.name}
                        </a>
                      ) : (
                        company.parent_entity.name
                      )}
                    </dd>
                  </div>
                )
              }
              {
                childCompanies.length > 0 && (
                  <div>
                    <dt class="text-xs text-muted-foreground">
                      Subsidiaries
                    </dt>
                    <dd class="text-sm font-medium">
                      <ul class="m-0 list-none space-y-1.5 p-0">
                        {childCompanies.map((child) => (
                          <li>
                            <a
                              href={`/companies/${child.slug}`}
                              class="text-primary hover:underline"
                            >
                              {child.name}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </dd>
                  </div>
                )
              }
              {
                (company.company_size || company.employee_count) && (
                  <div>
                    <dt class="text-xs text-muted-foreground">Company Size</dt>
                    <dd class="text-sm font-medium">
                      {(() => {
                        const entry = company.company_size ? getCompanySizeEntry(company.company_size) : null;
                        const count = company.employee_count;
                        if (entry) {
                          return (
                            <>
                              {entry.range}{" "}
                              <span class="font-normal text-muted-foreground">· {entry.label}</span>
                              {count != null && entry.id !== "1" && (
                                <span class="font-normal text-muted-foreground"> · {count} employees</span>
                              )}
                            </>
                          );
                        }
                        if (count != null) return <>{count} employees</>;
                        return company.company_size;
                      })()}
                    </dd>
                  </div>
                )
              }
              {
                company.contact_email && (
                  <div>
                    <dt class="text-xs text-muted-foreground">Contact</dt>
                    <dd class="text-sm font-medium">
                      <ObfuscatedEmail
                        email={company.contact_email}
                        class="text-primary hover:underline"
                      />
                    </dd>
                  </div>
                )
              }
              {
                company.legal_entities.length > 0 && company.legal_entities.map((entity) => (
                  <div>
                    <dt class="text-xs text-muted-foreground">Registered Name</dt>
                    <dd class="text-sm font-medium">
                      {entity.companies_house_number ? (
                        <a
                          href={`https://find-and-update.company-information.service.gov.uk/company/${entity.companies_house_number}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:underline"
                        >
                          {entity.uk_registered_name}
                        </a>
                      ) : (
                        entity.uk_registered_name
                      )}
                    </dd>
                  </div>
                ))
              }
            </dl>
            {
              company.website && (
                <a
                  href={company.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-5 flex h-9 w-full items-center justify-center rounded-md bg-primary text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
                >
                  Visit Website
                </a>
              )
            }
          </div>

        </aside>
      </div>
    </section>

    <!-- Games Section -->
    {
      showGamesTab && (
        <section id="games" data-tab-panel="games" class="hidden">
          <h2 class="mb-6 text-2xl font-semibold">Games</h2>

          {hasCategory("developer", "solo_developer") && (
            <div class="space-y-8">
              {inDevGames.length > 0 && (
                <div>
                  <h3 class="mb-3 text-lg font-medium text-muted-foreground">
                    In Development
                  </h3>
                  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                    {inDevGames.map((game) => (
                      <a
                        href={`/games/${game.slug}`}
                        class="group rounded-lg border border-border bg-card p-3 transition-colors hover:border-primary/30"
                      >
                        <div class="relative mb-2 flex aspect-[2/3] items-center justify-center overflow-hidden rounded-md bg-muted">
                          {game.cover_image ? (
                            <GameCoverImage client:load src={game.cover_image} forceFill={game.cover_fill} />
                          ) : (
                            <span
                              class="flex h-full w-full items-center justify-center rounded-md text-4xl font-bold text-white/60 select-none"
                              style={`background: ${getCoverGradient(game.title)}`}
                            >{game.title.charAt(0)}</span>
                          )}
                        </div>
                        <h4 class="text-sm font-medium group-hover:text-primary">
                          {game.title}
                        </h4>
                      </a>
                    ))}
                  </div>
                </div>
              )}
              {releasedGames.length > 0 && (
                <div>
                  <h3 class="mb-3 text-lg font-medium text-muted-foreground">
                    Released
                  </h3>
                  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                    {releasedGames.map((game) => (
                      <a
                        href={`/games/${game.slug}`}
                        class="group rounded-lg border border-border bg-card p-3 transition-colors hover:border-primary/30"
                      >
                        <div class="relative mb-2 flex aspect-[2/3] items-center justify-center overflow-hidden rounded-md bg-muted">
                          {game.cover_image ? (
                            <GameCoverImage client:load src={game.cover_image} forceFill={game.cover_fill} />
                          ) : (
                            <span
                              class="flex h-full w-full items-center justify-center rounded-md text-4xl font-bold text-white/60 select-none"
                              style={`background: ${getCoverGradient(game.title)}`}
                            >{game.title.charAt(0)}</span>
                          )}
                        </div>
                        <div class="flex items-start justify-between gap-2">
                          <h4 class="text-sm font-medium group-hover:text-primary">
                            {game.title}
                          </h4>
                          {Object.entries(game.critic_ratings)
                            .slice(0, 1)
                            .map(([, score]) => (
                              <span class="inline-flex items-center rounded bg-primary/10 px-1.5 py-0.5 text-[10px] font-semibold text-primary">
                                {score}
                              </span>
                            ))}
                        </div>
                        <p class="mt-0.5 text-xs text-muted-foreground">
                          {formatGameReleaseLineDisplay(game)}
                        </p>
                      </a>
                    ))}
                  </div>
                </div>
              )}
              {cancelledGames.length > 0 && (
                <div>
                  <h3 class="mb-3 text-lg font-medium text-muted-foreground">
                    Cancelled
                  </h3>
                  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                    {cancelledGames.map((game) => (
                      <a
                        href={`/games/${game.slug}`}
                        class="group rounded-lg border border-border bg-card p-3 opacity-60 transition-colors hover:border-primary/30"
                      >
                        <div class="relative mb-2 flex aspect-[2/3] items-center justify-center overflow-hidden rounded-md bg-muted">
                          {game.cover_image ? (
                            <GameCoverImage client:load src={game.cover_image} forceFill={game.cover_fill} />
                          ) : (
                            <span
                              class="flex h-full w-full items-center justify-center rounded-md text-4xl font-bold text-white/60 select-none"
                              style={`background: ${getCoverGradient(game.title)}`}
                            >{game.title.charAt(0)}</span>
                          )}
                        </div>
                        <h4 class="text-sm font-medium group-hover:text-primary">
                          {game.title}
                        </h4>
                      </a>
                    ))}
                  </div>
                </div>
              )}
              {prototypeGames.length > 0 && (
                <div>
                  <h3 class="mb-3 text-lg font-medium text-muted-foreground">
                    Prototypes &amp; Experiments
                  </h3>
                  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                    {prototypeGames.map((game) => (
                      <a
                        href={`/games/${game.slug}`}
                        class="group rounded-lg border border-dashed border-border bg-card/50 p-3 opacity-70 transition-colors hover:border-primary/30 hover:opacity-100"
                      >
                        <div class="relative mb-2 flex aspect-[2/3] items-center justify-center overflow-hidden rounded-md bg-muted">
                          {game.cover_image ? (
                            <GameCoverImage client:load src={game.cover_image} forceFill={game.cover_fill} />
                          ) : (
                            <span
                              class="flex h-full w-full items-center justify-center rounded-md text-4xl font-bold text-white/60 select-none"
                              style={`background: ${getCoverGradient(game.title)}`}
                            >{game.title.charAt(0)}</span>
                          )}
                        </div>
                        <h4 class="text-sm font-medium group-hover:text-primary">
                          {game.title}
                        </h4>
                        <p class="mt-0.5 text-xs text-muted-foreground">
                          {formatGameReleaseLineDisplay(game)}
                        </p>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}

          {contributedGames.length > 0 && (
            <div>
              <h3 class="mb-1 text-lg font-semibold">Contributed to</h3>
