---
import "leaflet/dist/leaflet.css";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllCompanies } from "@/lib/data";
import MapView from "@/components/companies/MapView";

const companies = await getAllCompanies();
const companiesWithCoords = companies
  .filter((c) => c.coordinates)
  .map((c) => ({
    id: c.id,
    name: c.name,
    slug: c.slug,
    categories: c.categories,
    location: c.location,
    coordinates: c.coordinates!,
  }));
---

<BaseLayout title="Companies Map">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight">Companies Map</h1>
      <p class="mt-2 text-muted-foreground">
        Explore Scottish games industry companies on the map.
      </p>
    </div>
    <div class="isolate overflow-hidden rounded-xl border border-border">
      <MapView client:only="react" companies={companiesWithCoords} />
    </div>
    <div class="mt-4">
      <a
        href="/companies/list"
        class="text-sm font-medium text-primary hover:underline"
      >
        &larr; Back to list view
      </a>
    </div>
  </div>
</BaseLayout>
