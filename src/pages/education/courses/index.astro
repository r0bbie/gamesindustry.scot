---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllSchools } from "@/lib/data";
import { GITHUB_REPO } from "@/lib/constants";
import CourseListView from "@/components/education/CourseListView";
import type { CourseItem } from "@/components/education/CourseListView";

const allSchools = await getAllSchools();
const schools = allSchools.filter((s) => s.status === "active");

// Flatten all courses from all active schools into a single list
const courses: CourseItem[] = schools.flatMap((school) =>
  (school.courses ?? []).map((course) => ({
    name: course.name,
    schoolId: school.id,
    schoolName: school.name,
    schoolSlug: school.slug,
    institutionType: school.institution_type,
    level: course.level,
    degree_type: course.degree_type,
    scqf_level: course.scqf_level ?? null,
    campus: course.campus ?? null,
    study_mode: course.study_mode ?? null,
    duration: course.duration ?? null,
    ucas_code: course.ucas_code ?? null,
    discipline: course.discipline,
    url: course.url,
    short_description: course.short_description,
  }))
);

const addSchoolUrl = `https://github.com/${GITHUB_REPO}/issues/new?template=add-school.yml&title=Add+School:+`;
---

<BaseLayout title="All Courses — Education">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <a href="/education" class="hover:text-foreground hover:underline">Education</a>
            <span>/</span>
            <span>All Courses</span>
          </div>
          <h1 class="mt-1 text-3xl font-bold tracking-tight">All Courses</h1>
          <p class="mt-2 max-w-2xl text-muted-foreground">
            Every game development, design, audio and creative course offered by Scottish universities and colleges.
          </p>
        </div>
        <a
          href={addSchoolUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 shrink-0 items-center gap-2 rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          Add a school
        </a>
      </div>
    </div>

    <CourseListView courses={courses} client:load />
  </div>
</BaseLayout>
