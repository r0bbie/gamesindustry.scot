---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllStudentGames,
  getAllSchools,
  getAllTeams,
} from "@/lib/data";
import {
  buildStoreUrl,
  buildPlayUrl,
  GITHUB_REPO,
} from "@/lib/constants";
import { Badge } from "@/components/ui/badge";

export async function getStaticPaths() {
  const games = await getAllStudentGames();
  return games.map((g) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const games = await getAllStudentGames();
const game = games.find((g) => g.slug === slug);
if (!game) return Astro.redirect("/404");

const schools = await getAllSchools();
const school = schools.find((s) => s.id === game.school_id);
if (!school) console.warn(`School "${game.school_id}" not found for student game "${game.id}"`);

const teams = await getAllTeams();
const team = game.team_id ? teams.find((t) => t.id === game.team_id) : null;
if (game.team_id && !team) console.warn(`Team "${game.team_id}" not found for student game "${game.id}"`);

const storeEntries = Object.entries(game.stores ?? {});
const playEntries = Object.entries(game.play_now ?? {});

const storeLabels: Record<string, string> = {
  steam: "Steam",
  epic: "Epic Games Store",
  gog: "GOG",
  itch: "itch.io",
  app_store: "App Store",
  play_store: "Google Play",
  game_jolt: "Game Jolt",
  newgrounds: "Newgrounds",
  poki: "Poki",
  crazygames: "CrazyGames",
};

const editUrl = `https://github.com/${GITHUB_REPO}/edit/main/data/education/games/${game.id}.json`;

const PLATFORM_NAMES: Record<string, string> = {
  pc: "PC", mac: "Mac", linux: "Linux", web: "Web",
  ios: "iOS", android: "Android", playstation: "PlayStation",
  xbox: "Xbox", switch: "Switch", vr: "VR",
};
const formatPlatform = (p: string) =>
  PLATFORM_NAMES[p.toLowerCase()] ?? p.charAt(0).toUpperCase() + p.slice(1);

function getVideoEmbedUrl(video: { type: string; id: string }): string {
  if (video.type === "youtube") return `https://www.youtube-nocookie.com/embed/${video.id}`;
  if (video.type === "vimeo") return `https://player.vimeo.com/video/${video.id}`;
  if (video.type === "peertube") return video.id;
  return "";
}

const gameDescClip = game.description
  ? game.description.replace(/\s+/g, " ").trim().slice(0, 155)
  : "";
const pageDescription = [
  gameDescClip,
  school ? `Student game · ${school.name}` : "Student game",
]
  .filter(Boolean)
  .join(" — ");
---

<BaseLayout title={game.title} description={pageDescription}>
  <!-- Header -->
  <section class="border-b border-border bg-card">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1 class="text-3xl font-bold tracking-tight">{game.title}</h1>
          <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted-foreground">
            {school && (
              <a
                href={`/education/schools/${school.slug}`}
                class="text-primary hover:underline"
              >
                {school.name}
              </a>
            )}
            {team && (
              <>
                <span>&middot;</span>
                <a
                  href={`/education/teams/${team.slug}`}
                  class="text-primary hover:underline"
                >
                  {team.name}
                </a>
              </>
            )}
          </div>
          {game.platforms.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {game.platforms.map((p) => (
                <Badge variant="secondary">{formatPlatform(p)}</Badge>
              ))}
            </div>
          )}
        </div>

        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 shrink-0 items-center gap-2 rounded-md border border-input bg-background px-3 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
          Suggest a change
        </a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-3">
      <div class="space-y-8 lg:col-span-2">
        <!-- Store / Play Links (top) -->
        {(storeEntries.length > 0 || playEntries.length > 0) && (
          <section>
            <div class="flex flex-wrap gap-2">
              {playEntries.map(([platform, id]) => (
                <a
                  href={buildPlayUrl(platform, id)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-lg border border-primary/30 bg-primary/5 px-3 py-2 text-sm font-medium text-primary shadow-sm transition-colors hover:bg-primary/10"
                >
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 3 19 12 5 21 5 3" />
                  </svg>
                  Play on {storeLabels[platform] ?? platform}
                </a>
              ))}
              {storeEntries.map(([store, id]) => (
                <a
                  href={buildStoreUrl(store, id)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                >
                  <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                  {storeLabels[store] ?? store}
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Video -->
        {game.video && (
          <section>
            <div class="aspect-video overflow-hidden rounded-xl border border-border">
              <iframe
                src={getVideoEmbedUrl(game.video)}
                title={`${game.title} video`}
                class="h-full w-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
          </section>
        )}

        <!-- Description -->
        {game.description && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">About</h2>
            <p class="whitespace-pre-line leading-relaxed text-muted-foreground">
              {game.description}
            </p>
          </section>
        )}

        <!-- Screenshots -->
        {game.screenshots.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Screenshots</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {game.screenshots.map((src, i) => (
                <div class="overflow-hidden rounded-lg border border-border">
                  <img
                    src={src}
                    alt={`${game.title} screenshot ${i + 1}`}
                    class="aspect-video w-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Game Jams & Competitions -->
        {game.competitions.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Game Jams &amp; Competitions</h2>
            <ul class="space-y-2">
              {game.competitions.map((comp) => {
                const badge =
                  comp.result === "winner"
                    ? { label: "Winner", class: "bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300" }
                    : comp.result === "runner-up"
                    ? { label: "Runner-up", class: "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300" }
                    : comp.result === "finalist"
                    ? { label: "Finalist", class: "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300" }
                    : { label: "Participated", class: "bg-muted text-muted-foreground" };
                return (
                  <li class="flex items-center justify-between rounded-lg border border-border bg-card px-4 py-3">
                    <span class="font-medium">{comp.name}</span>
                    <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge.class}`}>
                      {badge.label}
                    </span>
                  </li>
                );
              })}
            </ul>
          </section>
        )}

      </div>

      <!-- Sidebar -->
      <aside>
        <div class="rounded-xl border border-border bg-card p-5">
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
            Details
          </h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-muted-foreground">School</dt>
              <dd class="text-sm font-medium">
                {school ? (
                  <a
                    href={`/education/schools/${school.slug}`}
                    class="text-primary hover:underline"
                  >
                    {school.name}
                  </a>
                ) : (
                  "Unknown School"
                )}
              </dd>
            </div>
            {team && (
              <div>
                <dt class="text-xs text-muted-foreground">Team</dt>
                <dd class="text-sm font-medium">
                  <a
                    href={`/education/teams/${team.slug}`}
                    class="text-primary hover:underline"
                  >
                    {team.name}
                  </a>
                </dd>
              </div>
            )}
            {game.platforms.length > 0 && (
              <div>
                <dt class="text-xs text-muted-foreground">Platforms</dt>
                <dd class="mt-1 flex flex-wrap gap-1">
                  {game.platforms.map((p) => (
                    <span class="rounded bg-muted px-1.5 py-0.5 text-xs font-medium text-muted-foreground">
                      {formatPlatform(p)}
                    </span>
                  ))}
                </dd>
              </div>
            )}
          </dl>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
