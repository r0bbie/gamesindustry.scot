---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllSchools,
  getAllTeams,
  getAllStudentGames,
  type School,
} from "@/lib/data";
import {
  getDisciplineName,
  buildSocialUrl,
  GITHUB_REPO,
  SITE_URL,
} from "@/lib/constants";
import { Badge } from "@/components/ui/badge";
import TeamCard from "@/components/education/TeamCard.astro";

type Course = NonNullable<School["courses"]>[number];

export async function getStaticPaths() {
  const schools = await getAllSchools();
  return schools
    .filter((s) => s.status === "active")
    .map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const schools = await getAllSchools();
const school = schools.find((s) => s.slug === slug);
if (!school) return Astro.redirect("/404");

const allTeams = await getAllTeams();
const schoolTeams = allTeams.filter((t) => t.school_id === school.id);

const allStudentGames = await getAllStudentGames();
const schoolGames = allStudentGames.filter((g) => g.school_id === school.id);

const teamMap = new Map(allTeams.map((t) => [t.id, t]));

const GAME_PLATFORM_NAMES: Record<string, string> = {
  pc: "PC", mac: "Mac", linux: "Linux", web: "Web",
  ios: "iOS", android: "Android", playstation: "PlayStation",
  xbox: "Xbox", switch: "Switch", vr: "VR",
};
const formatPlatform = (p: string) =>
  GAME_PLATFORM_NAMES[p.toLowerCase()] ?? p.charAt(0).toUpperCase() + p.slice(1);

function formatPlatformName(platform: string): string {
  const names: Record<string, string> = {
    twitter: "Twitter / X",
    bluesky: "Bluesky",
    mastodon: "Mastodon",
    linkedin: "LinkedIn",
    youtube: "YouTube",
    github: "GitHub",
    instagram: "Instagram",
    discord: "Discord",
  };
  return (
    names[platform] ??
    platform.charAt(0).toUpperCase() + platform.slice(1).replace(/_/g, " ")
  );
}

const socialLinks = Object.entries(school.links ?? {}).map(
  ([platform, handle]) => ({
    platform,
    label: formatPlatformName(platform),
    url: buildSocialUrl(platform, handle as string),
  })
);

const editUrl = `https://github.com/${GITHUB_REPO}/edit/main/data/education/schools/${school.id}.json`;

const feCourses = school.courses.filter(
  (c: Course) => c.level === "further_education"
);
const undergradCourses = school.courses.filter(
  (c: Course) => c.level === "undergraduate"
);
const postgradCourses = school.courses.filter(
  (c: Course) => c.level === "postgraduate"
);
const distinctLevelGroups = [feCourses, undergradCourses, postgradCourses].filter(
  (g) => g.length > 0
);
const hasMultipleGroups = distinctLevelGroups.length > 1;
const iconBg = school.logo_bg === "light" ? "bg-white" : school.logo_bg === "dark" ? "bg-zinc-900" : "bg-muted";

// SEO metadata
const seoDescription = school.about?.trim()
  ? school.about.replace(/\s+/g, " ").slice(0, 200)
  : `${school.name} — games-related education in Scotland.`;
const ogImagePath = school.icon ?? school.logo ?? null;
const ogImage = ogImagePath
  ? (ogImagePath.startsWith("http") ? ogImagePath : `${SITE_URL}${ogImagePath}`)
  : undefined;

const schoolJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": school.institution_type === "university" ? "CollegeOrUniversity" : "EducationalOrganization",
  name: school.name,
  url: `${SITE_URL}/education/schools/${school.slug}`,
  ...(ogImage ? { logo: ogImage, image: ogImage } : {}),
  ...(school.about ? { description: school.about } : {}),
  ...(school.website ? { sameAs: [school.website, ...socialLinks.map((l) => l.url)].filter(Boolean) } : {}),
  ...(school.hq
    ? {
        address: {
          "@type": "PostalAddress",
          addressLocality: school.hq,
          addressCountry: "GB",
        },
      }
    : {}),
};
---

<BaseLayout
  title={school.name}
  description={seoDescription}
  image={ogImage}
  imageAlt={`${school.name} logo`}
  jsonLd={schoolJsonLd}
>
  <!-- Header -->
  <section class="border-b border-border bg-card">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-start gap-4">
          <div class={`flex h-16 w-16 shrink-0 items-center justify-center rounded-xl ${iconBg}`}>
            {(school.icon ?? school.logo) ? (
              <img
                src={school.icon ?? school.logo}
                alt={`${school.name} logo`}
                class="h-12 w-12 object-contain"
              />
            ) : (
              <svg class="h-8 w-8 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                <path d="M6 12v5c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2v-5" />
              </svg>
            )}
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="text-3xl font-bold tracking-tight">{school.name}</h1>
              {school.founded && (
                <span class="text-sm text-muted-foreground">
                  Est. {school.founded}
                </span>
              )}
            </div>
            {school.hq && (
              <p class="mt-1 text-muted-foreground">{school.hq}</p>
            )}
          </div>
        </div>

        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 shrink-0 items-center gap-2 rounded-md border border-input bg-background px-3 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
          Suggest a change
        </a>
      </div>

      {socialLinks.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {socialLinks.map(({ label, url }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-md border border-border px-2.5 py-1 text-xs font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              {label}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Main Content -->
      <div class="space-y-10 lg:col-span-2">
        <!-- About -->
        {school.about && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">About</h2>
            <p class="whitespace-pre-line leading-relaxed text-muted-foreground">
              {school.about}
            </p>
          </section>
        )}

        <!-- Disciplines -->
        {school.disciplines.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Disciplines</h2>
            <div class="flex flex-wrap gap-2">
              {school.disciplines.map((d: string) => (
                <Badge variant="secondary">{getDisciplineName(d)}</Badge>
              ))}
            </div>
          </section>
        )}

        <!-- Courses -->
        {school.courses.length > 0 && (
          <section>
            <h2 class="mb-4 text-xl font-semibold">Courses Offered</h2>
            {hasMultipleGroups ? (
              <div class="space-y-6">
                {(
                  [
                    { label: "Further Education", courses: feCourses },
                    { label: "Undergraduate", courses: undergradCourses },
                    { label: "Postgraduate", courses: postgradCourses },
                  ] as { label: string; courses: Course[] }[]
                )
                  .filter(({ courses }) => courses.length > 0)
                  .map(({ label, courses }) => (
                    <div>
                      <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
                        {label}
                      </h3>
                      <div class="space-y-3">
                        {courses.map((course: Course) => (
                          <div class="rounded-lg border border-border bg-card p-4">
                            <div class="flex items-start justify-between gap-4">
                              <div class="min-w-0 flex-1">
                                <div class="flex flex-wrap items-center gap-2">
                                  <span class="text-sm font-semibold leading-snug">{course.name}</span>
                                  {course.degree_type && (
                                    <span class="shrink-0 rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
                                      {course.degree_type}
                                    </span>
                                  )}
                                  {course.scqf_level && (
                                    <span class="shrink-0 rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
                                      SCQF L{course.scqf_level}
                                    </span>
                                  )}
                                  {course.discipline && (
                                    <Badge variant="secondary" className="shrink-0 text-[10px]">
                                      {getDisciplineName(course.discipline)}
                                    </Badge>
                                  )}
                                </div>
                                {(course.campus || course.study_mode || course.duration || course.ucas_code) && (
                                  <div class="mt-1 flex flex-wrap gap-x-3 gap-y-0.5 text-[11px] text-muted-foreground">
                                    {course.campus && <span>{course.campus}</span>}
                                    {course.study_mode && <span>{course.study_mode}</span>}
                                    {course.duration && <span>{course.duration}</span>}
                                    {course.ucas_code && <span>UCAS: {course.ucas_code}</span>}
                                  </div>
                                )}
                                {course.short_description && (
                                  <p class="mt-1.5 text-xs leading-relaxed text-muted-foreground">
                                    {course.short_description}
                                  </p>
                                )}
                              </div>
                              {course.url && (
                                <a
                                  href={course.url}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="inline-flex shrink-0 items-center gap-1 text-xs font-medium text-primary hover:underline"
                                >
                                  View course
                                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                    <polyline points="15 3 21 3 21 9" />
                                    <line x1="10" y1="14" x2="21" y2="3" />
                                  </svg>
                                </a>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  ))}
              </div>
            ) : (
              <div class="space-y-3">
                {school.courses.map((course: Course) => (
                  <div class="rounded-lg border border-border bg-card p-4">
                    <div class="flex items-start justify-between gap-4">
                      <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-center gap-2">
                          <span class="text-sm font-semibold leading-snug">{course.name}</span>
                          {course.degree_type && (
                            <span class="shrink-0 rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
                              {course.degree_type}
                            </span>
                          )}
                          {course.scqf_level && (
                            <span class="shrink-0 rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
                              SCQF L{course.scqf_level}
                            </span>
                          )}
                          {course.discipline && (
                            <Badge variant="secondary" className="shrink-0 text-[10px]">
                              {getDisciplineName(course.discipline)}
                            </Badge>
                          )}
                        </div>
                        {(course.campus || course.study_mode || course.duration || course.ucas_code) && (
                          <div class="mt-1 flex flex-wrap gap-x-3 gap-y-0.5 text-[11px] text-muted-foreground">
                            {course.campus && <span>{course.campus}</span>}
                            {course.study_mode && <span>{course.study_mode}</span>}
                            {course.duration && <span>{course.duration}</span>}
                            {course.ucas_code && <span>UCAS: {course.ucas_code}</span>}
                          </div>
                        )}
                        {course.short_description && (
                          <p class="mt-1.5 text-xs leading-relaxed text-muted-foreground">
                            {course.short_description}
                          </p>
                        )}
                      </div>
                      {course.url && (
                        <a
                          href={course.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex shrink-0 items-center gap-1 text-xs font-medium text-primary hover:underline"
                        >
                          View course
                          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                            <polyline points="15 3 21 3 21 9" />
                            <line x1="10" y1="14" x2="21" y2="3" />
                          </svg>
                        </a>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </section>
        )}

        <!-- Student Teams -->
        {schoolTeams.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Student Teams</h2>
            <div class="grid gap-4 sm:grid-cols-2">
              {schoolTeams.map((team) => (
                <TeamCard team={team} schoolName={school.name} />
              ))}
            </div>
          </section>
        )}

        <!-- Student Games -->
        {schoolGames.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Student Games</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {schoolGames.map((game) => {
                const team = game.team_id ? teamMap.get(game.team_id) : null;
                return (
                  <a
                    href={`/education/games/${game.slug}`}
                    class="group rounded-lg border border-border bg-card p-3 transition-colors hover:border-primary/30"
                  >
                    <h4 class="text-sm font-medium group-hover:text-primary">
                      {game.title}
                    </h4>
                    {team && (
                      <p class="mt-0.5 text-xs text-muted-foreground">
                        by {team.name}
                      </p>
                    )}
                    {game.platforms.length > 0 && (
                      <div class="mt-2 flex flex-wrap gap-1">
                        {game.platforms.map((p: string) => (
                          <span class="rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
                            {formatPlatform(p)}
                          </span>
                        ))}
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside>
        <div class="rounded-xl border border-border bg-card p-5">
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
            Details
          </h3>
          <dl class="space-y-3">
            {school.founded && (
              <div>
                <dt class="text-xs text-muted-foreground">Founded</dt>
                <dd class="text-sm font-medium">{school.founded}</dd>
              </div>
            )}
            {school.hq && (
              <div>
                <dt class="text-xs text-muted-foreground">HQ</dt>
                <dd class="text-sm font-medium">{school.hq}</dd>
              </div>
            )}
            {school.campuses.length > 0 && (
              <div>
                <dt class="text-xs text-muted-foreground">Campuses</dt>
                <dd class="mt-0.5 text-sm">{school.campuses.join(", ")}</dd>
              </div>
            )}
          </dl>
          {school.website && (
            <a
              href={school.website}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 flex h-9 w-full items-center justify-center rounded-md bg-primary text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
            >
              Visit Website
            </a>
          )}
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
