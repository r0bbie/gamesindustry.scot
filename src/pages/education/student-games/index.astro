---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllStudentGames, getAllSchools, getAllTeams } from "@/lib/data";
import { buildPlayUrl, buildStoreUrl } from "@/lib/constants";

const studentGames = await getAllStudentGames();
const allSchools = await getAllSchools();
const teams = await getAllTeams();

const schoolMap = new Map(allSchools.map((s) => [s.id, s]));
const teamMap = new Map(teams.map((t) => [t.id, t]));

const PLATFORM_NAMES: Record<string, string> = {
  pc: "PC",
  mac: "Mac",
  linux: "Linux",
  web: "Web",
  ios: "iOS",
  android: "Android",
  playstation: "PlayStation",
  xbox: "Xbox",
  switch: "Switch",
  vr: "VR",
};
const formatPlatform = (p: string) => PLATFORM_NAMES[p.toLowerCase()] ?? p.charAt(0).toUpperCase() + p.slice(1);

const PLAY_LABELS: Record<string, string> = {
  itch: "Play on Itch.io",
};
const getPlayLabel = (platform: string) =>
  PLAY_LABELS[platform.toLowerCase()] ?? `Play on ${platform.charAt(0).toUpperCase() + platform.slice(1)}`;

const STORE_LABELS: Record<string, string> = {
  steam: "Play on Steam",
};
const getStoreLabel = (store: string) =>
  STORE_LABELS[store.toLowerCase()] ?? store.charAt(0).toUpperCase() + store.slice(1);

const games = studentGames.map((g) => ({
  ...g,
  school: schoolMap.get(g.school_id),
  team: g.team_id ? teamMap.get(g.team_id) : undefined,
}));
---

<BaseLayout
  title="Student Games — Education"
  description="Games developed by students at Scottish universities and colleges."
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href="/education" class="hover:text-foreground hover:underline">Education</a>
        <span>/</span>
        <span>Student Games</span>
      </div>
      <h1 class="mt-1 text-3xl font-bold tracking-tight">Student Games</h1>
      <p class="mt-2 max-w-2xl text-muted-foreground">
        Games created by student teams at Scottish universities and colleges.
      </p>
    </div>

    {games.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {games.map(({ id, title, slug, description, platforms, stores, play_now, video, competitions, school, team }) => (
          <div class="flex flex-col rounded-xl border border-border bg-card shadow-sm">
            <!-- Card body -->
            <div class="flex flex-1 flex-col p-5">
              <div class="mb-1">
                <div class="flex flex-wrap items-center gap-2">
                  <h2 class="font-semibold leading-snug tracking-tight">
                    <a href={`/education/games/${slug}`} class="hover:text-primary hover:underline">{title}</a>
                  </h2>
                  {competitions?.filter(c => c.result === "winner" || c.result === "runner-up").map(c => (
                    <span
                      title={c.result === "winner" ? "Winner" : "Runner-up"}
                      class={`shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold ${
                        c.result === "winner"
                          ? "bg-amber-400/20 text-amber-700 dark:bg-amber-400/20 dark:text-amber-300 ring-1 ring-amber-400/60"
                          : "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300"
                      }`}
                    >
                      {c.name}
                    </span>
                  ))}
                </div>
                {platforms.length > 0 && (
                  <div class="mt-1 flex flex-wrap gap-1">
                    {platforms.map((p) => (
                      <span class="rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground">
                        {formatPlatform(p)}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              {(school || team) && (
                <p class="mb-3 text-xs text-muted-foreground">
                  {team?.name ?? ""}
                  {team && school && " · "}
                  {school ? (
                    <a href={`/education/schools/${school.slug}`} class="hover:text-foreground hover:underline">
                      {school.name}
                    </a>
                  ) : null}
                </p>
              )}

              {description && (
                <p class="line-clamp-3 text-sm text-muted-foreground">{description}</p>
              )}

              <!-- Video link -->
              {video && (
                <a
                  href={`/education/games/${slug}`}
                  class="mt-3 flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground"
                >
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  Watch trailer
                </a>
              )}

              <!-- Play / Store links -->
              {(Object.keys(play_now).length > 0 || Object.keys(stores).length > 0) && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {Object.entries(play_now).map(([platform, id]) => (
                    <a
                      href={buildPlayUrl(platform, id)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex h-8 items-center gap-1.5 rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground transition-colors hover:bg-primary/90"
                    >
                      {platform.toLowerCase() === "itch" && (
                        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 245.37 220.72" fill="currentColor" aria-hidden="true">
                          <path d="M31.99 1.365C21.287 7.72.2 31.945 0 38.298v10.516C0 62.144 12.46 73.86 23.773 73.86c13.584 0 24.902-11.258 24.902-24.62 0 13.362 10.93 24.62 24.515 24.62 13.586 0 24.165-11.258 24.165-24.62 0 13.362 11.622 24.62 25.207 24.62h.246c13.586 0 25.208-11.258 25.208-24.62 0 13.362 10.58 24.62 24.164 24.62 13.585 0 24.515-11.258 24.515-24.62 0 13.362 11.32 24.62 24.903 24.62 11.313 0 23.773-11.716 23.773-25.046V38.298c-.2-6.353-21.287-30.578-32-36.933C220.86.702 25.375.068 31.99 1.365zm80.868 60.26c-3.978 10.567-14.873 18.168-27.546 18.168-15.49 0-28.274-12.538-28.274-27.874 0 15.336-13.387 27.874-29.15 27.874-2.985 0-5.886-.44-8.617-1.23 4.056 15.046 5.69 32.432 5.69 51.66 0 2.675-.067 5.317-.2 7.925 7.94 4.11 27.214 11.87 75.17 11.87 48.44 0 67.48-7.994 75.3-12.07-.12-2.56-.18-5.15-.18-7.725 0-19.23 1.636-36.61 5.692-51.66-2.73.79-5.63 1.23-8.617 1.23-15.763 0-29.15-12.538-29.15-27.874 0 15.336-12.784 27.874-28.274 27.874-12.673 0-23.568-7.6-27.546-18.168zM.002 136.89C2.29 170.685 10.89 200.095 24.58 220.72h196.21c13.69-20.625 22.29-50.035 24.58-83.83-7.94 4.11-27.214 11.87-75.17 11.87-48.44 0-67.48-7.994-75.3-12.07-7.94 4.11-27.214 11.87-75.17 11.87-2.985 0-5.886-.044-8.617-.834l-.11 1.065z"/>
                        </svg>
                      )}
                      {getPlayLabel(platform)}
                    </a>
                  ))}
                  {Object.entries(stores).map(([store, id]) => (
                    <a
                      href={buildStoreUrl(store, id)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex h-8 items-center gap-1.5 rounded-md border border-input bg-background px-3 text-xs font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
                    >
                      {store.toLowerCase() === "steam" && (
                        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/>
                        </svg>
                      )}
                      {getStoreLabel(store)}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="rounded-xl border border-border bg-card px-6 py-16 text-center">
        <p class="text-muted-foreground">No student games listed yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
