---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllEvents, safeGetCompany } from "@/lib/data";
import { EVENT_TAGS, GITHUB_REPO } from "@/lib/constants";
import { BrokenLink } from "@/components/ui/broken-link";

export async function getStaticPaths() {
  const events = await getAllEvents();
  return events.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const events = await getAllEvents();
const event = events.find((e) => e.slug === slug);

if (!event) {
  return Astro.redirect("/404");
}

const company = event.company_id
  ? await safeGetCompany(event.company_id, `event:${event.slug}`)
  : null;

function getTagName(tagId: string): string {
  return EVENT_TAGS.find((t) => t.id === tagId)?.name ?? tagId;
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString("en-GB", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
    });
  } catch {
    return dateStr;
  }
}

function formatDateRange(start: string, end?: string): string {
  if (!end || end === start) return formatDate(start);
  const startD = new Date(start);
  const endD = new Date(end);
  if (startD.getMonth() === endD.getMonth() && startD.getFullYear() === endD.getFullYear()) {
    const startStr = startD.toLocaleDateString("en-GB", { weekday: "long", day: "numeric" });
    return `${startStr} – ${formatDate(end)}`;
  }
  return `${formatDate(start)} – ${formatDate(end)}`;
}

function googleCalendarUrl(ev: typeof event): string {
  const start = ev.date_start.replace(/-/g, "");
  const end = ev.date_end ? ev.date_end.replace(/-/g, "") : start;
  const params = new URLSearchParams({
    action: "TEMPLATE",
    text: ev.name,
    dates: `${start}/${end}`,
    details: ev.description || "",
    location: ev.location || "",
  });
  return `https://calendar.google.com/calendar/render?${params}`;
}

const editUrl = `https://github.com/${GITHUB_REPO}/edit/main/data/events/${event.slug}.json`;
const gcalUrl = googleCalendarUrl(event);
const displayLocation = event.is_online ? "Online" : (event.location ?? "TBC");
---

<BaseLayout
  title={event.name}
  description={event.short_description ?? `${event.name} — an event for the Scottish games industry.`}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-muted-foreground">
      <a href="/events" class="hover:text-foreground transition-colors">Events</a>
      <span class="mx-1.5">/</span>
      <span class="text-foreground">{event.name}</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-start gap-3">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{event.name}</h1>
        {event.is_scottish && (
          <span class="mt-1 shrink-0 text-2xl" title="Scottish event">🏴󠁧󠁢󠁳󠁣󠁴󠁿</span>
        )}
      </div>

      {/* Tags */}
      {event.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {event.tags.map((tag) => (
            <span class="inline-flex items-center rounded-md border border-transparent bg-secondary px-2.5 py-0.5 text-xs font-semibold text-secondary-foreground">
              {getTagName(tag)}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Details card -->
    <div class="mb-8 rounded-xl border border-border bg-card p-6 shadow">
      <dl class="grid gap-4 sm:grid-cols-2">
        {/* Date */}
        <div>
          <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Date</dt>
          <dd class="mt-1 flex items-center gap-2 text-sm font-medium">
            <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            {formatDateRange(event.date_start, event.date_end)}
          </dd>
        </div>

        {/* Time */}
        {event.time && (
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Time</dt>
            <dd class="mt-1 flex items-center gap-2 text-sm font-medium">
              <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {event.time}
            </dd>
          </div>
        )}

        {/* Location */}
        <div>
          <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Location</dt>
          <dd class="mt-1 flex items-center gap-2 text-sm font-medium">
            {event.is_online ? (
              <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            ) : (
              <svg class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            )}
            {displayLocation}
          </dd>
        </div>
      </dl>
    </div>

    {/* Action buttons */}
    <div class="mb-8 flex flex-wrap gap-2">
      {event.website && (
        <a
          href={event.website}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Attend
        </a>
      )}
      <a
        href={gcalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-10 items-center gap-2 rounded-md border border-input bg-background px-5 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
        Add to calendar
      </a>
    </div>

    {/* Description */}
    {event.description && (
      <section class="mb-8">
        <div class="prose prose-neutral dark:prose-invert max-w-none rounded-xl border border-border bg-card p-6">
          <p>{event.description}</p>
        </div>
      </section>
    )}

    {/* Organiser */}
    {event.company_id && (
      <section class="mb-8">
        <h2 class="mb-3 text-xl font-semibold">Organiser</h2>
        {company ? (
          <a
            href={`/companies/${company.slug}`}
            class="flex items-center gap-3 rounded-xl border border-border bg-card p-4 transition-colors hover:border-primary/30 hover:bg-accent/50"
          >
            <div class={`flex h-10 w-10 items-center justify-center rounded-lg ${company.logo_bg === "light" ? "bg-white" : company.logo_bg === "dark" ? "bg-zinc-900" : "bg-muted"}`}>
              {company.logo ? (
                <img src={company.logo} alt="" class="h-8 w-8 rounded-md object-contain" />
              ) : (
                <svg class="h-5 w-5 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></svg>
              )}
            </div>
            <div>
              <p class="font-semibold">{company.name}</p>
              {company.short_description && (
                <p class="text-sm text-muted-foreground">{company.short_description}</p>
              )}
            </div>
          </a>
        ) : (
          <BrokenLink id={event.company_id} type="company" />
        )}
      </section>
    )}

    {/* Suggest a change */}
    <div class="border-t border-border pt-6 text-center">
      <p class="text-sm text-muted-foreground">
        See something wrong?{" "}
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-primary hover:underline"
        >
          Suggest a change on GitHub
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
