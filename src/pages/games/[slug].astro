---
import BaseLayout from "@/layouts/BaseLayout.astro";
import criticScoreCache from "../../../data/cache/critic-scores.json";
import {
  getAllGames,
  getGameBySlug,
  getNewsForGame,
  safeGetCompany,
  resolveCompanyRefs,
} from "@/lib/data";
import {
  buildStoreUrl,
  buildPlayUrl,
  buildCriticUrl,
  buildDatabaseUrl,
  getAwardStatusLabel,
  GITHUB_REPO,
  SITE_URL,
} from "@/lib/constants";
import PlatformIcons from "@/components/games/PlatformIcons.astro";
import StoreLinks from "@/components/games/StoreLinks.astro";
import PhysicalStoreLinks from "@/components/games/PhysicalStoreLinks.astro";
import GameCoverImage from "@/components/games/GameCoverImage";
import { BrokenLink } from "@/components/ui/broken-link";
import {
  formatReleaseDatePart,
  formatGameReleaseLineDisplay,
  useWishlistStoreHeading,
} from "@/lib/gameRelease";

export async function getStaticPaths() {
  const games = await getAllGames();
  return games.map((g) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const game = await getGameBySlug(slug!);

if (!game) {
  return Astro.redirect("/404");
}

// Resolve developer companies
const developers = await resolveCompanyRefs(
  game.companies.developer,
  `game:${game.slug}`,
);
const publishers = await resolveCompanyRefs(
  game.companies.publishers,
  `game:${game.slug}`,
);
const contributors = await resolveCompanyRefs(
  game.companies.contributed_by,
  `game:${game.slug}`,
);
const serviceCompanies = await resolveCompanyRefs(
  game.companies.service_companies,
  `game:${game.slug}`,
);
const tooling = await resolveCompanyRefs(
  game.companies.used_tooling,
  `game:${game.slug}`,
);
const supportedBy = await resolveCompanyRefs(
  game.companies.supported_by,
  `game:${game.slug}`,
);

const primaryDev = developers[0]?.company;

const statusLabels: Record<string, string> = {
  released: "Released",
  in_development: "In Development",
  cancelled: "Cancelled",
};
const statusColors: Record<string, string> = {
  released: "border-green-500/40 bg-green-500/10 text-green-700 dark:text-green-400",
  in_development: "border-blue-500/40 bg-blue-500/10 text-blue-700 dark:text-blue-400",
  cancelled: "border-red-500/40 bg-red-500/10 text-red-700 dark:text-red-400",
};

const formatDate = formatReleaseDatePart;

function getCoverGradient(title: string): string {
  const hue = [...title].reduce((sum, ch) => sum + ch.charCodeAt(0), 0) % 360;
  return `linear-gradient(135deg, hsl(${hue}, 60%, 35%), hsl(${(hue + 50) % 360}, 50%, 25%))`;
}

const criticLabels: Record<string, string> = {
  metacritic: "Metacritic",
  opencritic: "OpenCritic",
  criticdb: "CriticDB",
};

const databaseLabels: Record<string, string> = {
  igdb: "IGDB",
  mobygames: "MobyGames",
  backloggd: "Backloggd",
  rawg: "RAWG",
  glitchwave: "Glitchwave",
  gamefaqs: "GameFAQs",
  wikipedia: "Wikipedia",
  facebook: "Facebook",
  wiki: "Wiki",
};

const officialSiteUrl = game.stores.website ?? null;
const pressKitUrl = game.press_kit_url ?? null;
const storeEntries = Object.entries(game.stores).filter(([k]) => k !== "website");
const buyStores = Object.fromEntries(storeEntries) as Record<string, string>;
const playNowEntries = Object.entries(game.play_now);
const physicalEntries = Object.entries(game.physical_stores);

const storeHeadingFields = {
  status: game.status,
  release_date: game.release_date,
  release_period: game.release_period,
};
const storeBuyLabel = useWishlistStoreHeading(storeHeadingFields, new Date())
  ? "Wishlist"
  : "Buy";
// Merge live cached scores (from prebuild fetch) over static JSON values
const liveCriticScores = (criticScoreCache as Record<string, Record<string, number>>)[game.id] ?? {};
const ratingMap = { ...game.critic_ratings, ...liveCriticScores };
const criticIdKeys = Object.keys(game.critic_ids ?? {}).filter(
  (k) => k in criticLabels && ratingMap[k as keyof typeof ratingMap] === undefined,
);
const criticEntries: [string, string | number][] = [
  ...(Object.entries(ratingMap) as [string, string | number][]),
  ...criticIdKeys.map((k) => [k, "—"] as [string, string | number]),
];
const databaseEntries = Object.entries(game.database_links);
const sortedAwards = [...game.awards].sort((a, b) => b.year - a.year);
const hasAwards = sortedAwards.length > 0;
const gameNews = await getNewsForGame(game.id);
const hasNews = gameNews.length > 0;
const hasScreenshots = game.screenshots.length > 0;

const editUrl = `https://github.com/${GITHUB_REPO}/edit/main/data/games/${game.slug.charAt(0)}/${game.slug}.json`;

// Pagefind result excerpt — short_description if set, otherwise a concise
// "<Status> · <Developer>" fallback (e.g. "Released · Denki").
const searchSummary = (() => {
  const desc = (game.short_description ?? "").trim();
  if (desc) return desc;
  const parts = [
    statusLabels[game.status],
    primaryDev?.name,
  ].filter(Boolean);
  return parts.join(" · ") || "Game from Scotland";
})();

// SEO metadata
const seoDescription = game.short_description?.trim()
  || (primaryDev?.name
    ? `${game.title} — ${statusLabels[game.status] ?? "a game"} by ${primaryDev.name}.`
    : `${game.title} — a game made in Scotland.`);

const ogImage = game.cover_image
  ? (game.cover_image.startsWith("http") ? game.cover_image : `${SITE_URL}${game.cover_image}`)
  : undefined;

// schema.org VideoGame markup. Improves rich-result eligibility on Google
// (genre, platform, developer, publisher, release date).
const videoGameJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "VideoGame",
  name: game.title,
  url: `${SITE_URL}/games/${game.slug}`,
  ...(ogImage ? { image: ogImage } : {}),
  ...(game.short_description ? { description: game.short_description } : {}),
  ...(game.genres?.length ? { genre: game.genres } : {}),
  ...(game.platforms?.length ? { gamePlatform: game.platforms } : {}),
  ...(game.release_date && /^\d{4}-\d{2}-\d{2}$/.test(game.release_date)
    ? { datePublished: game.release_date }
    : {}),
  ...(developers.length
    ? {
        author: developers.map((d) => ({
          "@type": "Organization",
          name: d.company?.name ?? d.name,
          ...(d.company?.slug
            ? { url: `${SITE_URL}/companies/${d.company.slug}` }
            : d.url
              ? { url: d.url }
              : {}),
        })),
      }
    : {}),
  ...(publishers.length
    ? {
        publisher: publishers.map((p) => ({
          "@type": "Organization",
          name: p.company?.name ?? p.name,
          ...(p.company?.slug
            ? { url: `${SITE_URL}/companies/${p.company.slug}` }
            : p.url
              ? { url: p.url }
              : {}),
        })),
      }
    : {}),
};
---

<BaseLayout
  title={game.title}
  description={seoDescription}
  image={ogImage}
  imageAlt={`${game.title} cover art`}
  jsonLd={videoGameJsonLd}
>
  <span data-pagefind-meta="summary" hidden>{searchSummary}</span>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Hero -->

    <!-- Mobile-only header: title, byline, date shown above the cover -->
    <div class="mb-4 sm:hidden">
      <h1 class="text-3xl font-bold tracking-tight">{game.title}</h1>

      <div class="mt-2 flex flex-wrap items-center gap-1 text-base text-muted-foreground">
        <span>By</span>
        {developers.map(({ id, name, url, company }, i) => (
          <>
            {i > 0 && <span>,</span>}
            {company ? (
              <a
                href={`/companies/${company.slug}`}
                class="font-medium text-foreground hover:text-primary transition-colors"
              >
                {name}
              </a>
            ) : url ? (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="font-medium text-foreground hover:text-primary transition-colors"
              >
                {name}
              </a>
            ) : id !== null ? (
              <BrokenLink id={id} type="company" />
            ) : (
              <span class="font-medium text-foreground">{name}</span>
            )}
          </>
        ))}
        {developers.length === 0 && (
          <span class="text-muted-foreground">Unknown Developer</span>
        )}
      </div>

      {contributors.length > 0 && (
        <div class="mt-0.5 flex flex-wrap items-center gap-1 text-sm text-muted-foreground">
          <span>with</span>
          {contributors.map(({ id, name, url, company }, i) => (
            <>
              {i > 0 && <span>,</span>}
              {company ? (
                <a href={`/companies/${company.slug}`} class="hover:text-foreground transition-colors">{name}</a>
              ) : url ? (
                <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">{name}</a>
              ) : id !== null ? (
                <BrokenLink id={id} type="company" />
              ) : (
                <span>{name}</span>
              )}
            </>
          ))}
        </div>
      )}

      <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
            <line x1="16" x2="16" y1="2" y2="6" />
            <line x1="8" x2="8" y1="2" y2="6" />
            <line x1="3" x2="21" y1="10" y2="10" />
          </svg>
          {formatGameReleaseLineDisplay(game)}
        </span>
      </div>
    </div>

    <div class="mb-10 grid gap-8 sm:grid-cols-[220px_1fr] lg:grid-cols-[320px_1fr]">
      <!-- Cover -->
      <div class="relative flex aspect-[2/3] items-center justify-center overflow-hidden rounded-xl border border-border shadow-lg"
        style={!game.cover_image ? `background: ${getCoverGradient(game.title)};` : ""}
      >
        {game.cover_image ? (
          <>
            {/* Hidden static <img> tells Pagefind the canonical cover for
                search-result thumbnails. The visible cover is a React island
                so Pagefind's image heuristic might miss it. */}
            <img
              src={game.cover_image}
              alt={`${game.title} cover art`}
              data-pagefind-meta="image[src], image_alt[alt]"
              aria-hidden="true"
              hidden
            />
            <GameCoverImage client:load src={game.cover_image} alt={`${game.title} cover art`} forceFill={game.cover_fill} />
          </>
        ) : (
          <span class="text-7xl font-bold text-white/60">{game.title.charAt(0)}</span>
        )}
      </div>

      <!-- Info -->
      <div class="flex flex-col justify-center">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span
            class:list={[
              "inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold",
              statusColors[game.status] ?? "border-border bg-muted text-muted-foreground",
            ]}
          >
            {statusLabels[game.status] ?? game.status}
          </span>
          {game.genres.map((genre) => (
            <span class="inline-flex items-center rounded-md border border-border bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
              {genre}
            </span>
          ))}
        </div>

        <h1 class="hidden text-4xl font-bold tracking-tight sm:block lg:text-5xl">{game.title}</h1>

        <!-- Developer byline -->
        <div class="mt-3 hidden flex-wrap items-center gap-1 text-lg text-muted-foreground sm:flex">
          <span>By</span>
          {developers.map(({ id, name, url, company }, i) => (
            <>
              {i > 0 && <span>,</span>}
              {company ? (
                <a
                  href={`/companies/${company.slug}`}
                  class="font-medium text-foreground hover:text-primary transition-colors"
                >
                  {name}
                </a>
              ) : url ? (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-foreground hover:text-primary transition-colors"
                >
                  {name}
                </a>
              ) : id !== null ? (
                <BrokenLink id={id} type="company" />
              ) : (
                <span class="font-medium text-foreground">{name}</span>
              )}
            </>
          ))}
          {developers.length === 0 && (
            <span class="text-muted-foreground">Unknown Developer</span>
          )}
        </div>

        {contributors.length > 0 && (
          <div class="mt-1 hidden flex-wrap items-center gap-1 text-sm text-muted-foreground sm:flex">
            <span>with</span>
            {contributors.map(({ id, name, url, company }, i) => (
              <>
                {i > 0 && <span>,</span>}
                {company ? (
                  <a
                    href={`/companies/${company.slug}`}
                    class="hover:text-foreground transition-colors"
                  >
                    {name}
                  </a>
                ) : url ? (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-foreground transition-colors"
                  >
                    {name}
                  </a>
                ) : id !== null ? (
                  <BrokenLink id={id} type="company" />
                ) : (
                  <span>{name}</span>
                )}
              </>
            ))}
          </div>
        )}

        <div class="mt-3 hidden flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground sm:flex">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
              <line x1="16" x2="16" y1="2" y2="6" />
              <line x1="8" x2="8" y1="2" y2="6" />
              <line x1="3" x2="21" y1="10" y2="10" />
            </svg>
            {formatGameReleaseLineDisplay(game)}
          </span>
        </div>

        {game.short_description && (
          <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
            {game.short_description}
          </p>
        )}

        {game.platforms.length > 0 && (
          <div class="mt-4">
            <PlatformIcons platforms={game.platforms} size="md" />
          </div>
        )}

        {officialSiteUrl && (
          <div class="mt-3">
            <a
              href={officialSiteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              <svg
                class="h-4 w-4 shrink-0 text-muted-foreground"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
                <path d="M2 12h20" />
              </svg>
              Official Site
            </a>
          </div>
        )}
      </div>
    </div>

    {/* Buy / Play / Physical links */}
    {(storeEntries.length > 0 || playNowEntries.length > 0 || physicalEntries.length > 0) && (
      <div class="mb-10 flex flex-wrap gap-6">
        {storeEntries.length > 0 && (
          <div>
            <p
              id="store-buy-label"
              class="mb-2 text-xs font-medium uppercase tracking-wider text-muted-foreground"
            >
              {storeBuyLabel}
            </p>
            <StoreLinks stores={buyStores} type="buy" />
          </div>
        )}
        {playNowEntries.length > 0 && (
          <div>
            <p class="mb-2 text-xs font-medium uppercase tracking-wider text-muted-foreground">Play Now</p>
            <StoreLinks stores={game.play_now} type="play" />
          </div>
        )}
        {physicalEntries.length > 0 && (
          <div>
            <p class="mb-2 text-xs font-medium uppercase tracking-wider text-muted-foreground">Physical</p>
            <PhysicalStoreLinks stores={game.physical_stores} />
          </div>
        )}
      </div>
    )}

    {/* Full description — blank-line (\n\n) separates paragraphs */}
    {game.description && (
      <section class="mb-10">
        <div class="flex max-w-none flex-col gap-4 rounded-xl border border-border bg-card p-6 leading-relaxed text-foreground">
          {game.description
            .split(/\n\n+/)
            .map((para) => para.trim())
            .filter(Boolean)
            .map((para) => (
              <p>{para}</p>
            ))}
        </div>
      </section>
    )}

    <div class="grid gap-10 lg:grid-cols-[1fr_320px]">
      <div class="space-y-10">
        {/* Video */}
        {game.video && (
          <section>
            <h2 class="mb-4 text-xl font-semibold">Video</h2>
            <div class="aspect-video overflow-hidden rounded-xl border border-border shadow">
              {game.video.type === "youtube" ? (
                <iframe
                  src={`https://www.youtube.com/embed/${game.video.id}`}
                  title={`${game.title} video`}
                  class="h-full w-full"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              ) : game.video.type === "vimeo" ? (
                <iframe
                  src={`https://player.vimeo.com/video/${game.video.id}`}
                  title={`${game.title} video`}
                  class="h-full w-full"
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen
                />
              ) : (
                <iframe
                  src={`https://${game.video.id}`}
                  title={`${game.title} video`}
                  class="h-full w-full"
                  allowfullscreen
                />
              )}
            </div>
          </section>
        )}

        {/* Screenshots */}
        {hasScreenshots && (
          <section>
            <h2 class="mb-4 text-xl font-semibold">Screenshots</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {game.screenshots.map((src, i) => (
                <img
                  src={src}
                  alt={`${game.title} screenshot ${i + 1}`}
                  class="rounded-lg border border-border object-cover shadow"
                  loading="lazy"
                />
              ))}
            </div>
          </section>
        )}

        {/* Company Connections */}
        {publishers.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Publishers</h2>
            <div class="flex flex-wrap gap-2">
              {publishers.map(({ id, name, url, company }) =>
                company ? (
                  <a
                    href={`/companies/${company.slug}`}
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {company.name}
                  </a>
                ) : id !== null ? (
                  <BrokenLink id={id} type="company" />
                ) : url ? (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {name}
                  </a>
                ) : (
                  <span class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm">
                    {name}
                  </span>
                ),
              )}
            </div>
          </section>
        )}

        {serviceCompanies.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Service Companies</h2>
            <div class="flex flex-wrap gap-2">
              {serviceCompanies.map(({ id, name, url, company }) =>
                company ? (
                  <a
                    href={`/companies/${company.slug}`}
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {company.name}
                  </a>
                ) : id !== null ? (
                  <BrokenLink id={id} type="company" />
                ) : url ? (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {name}
                  </a>
                ) : (
                  <span class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm">
                    {name}
                  </span>
                ),
              )}
            </div>
          </section>
        )}

        {tooling.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Tooling Used</h2>
            <div class="flex flex-wrap gap-2">
              {tooling.map(({ id, name, url, company }) =>
                company ? (
                  <a
                    href={`/companies/${company.slug}`}
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {company.name}
                  </a>
                ) : id !== null ? (
                  <BrokenLink id={id} type="company" />
                ) : url ? (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {name}
                  </a>
                ) : (
                  <span class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm">
                    {name}
                  </span>
                ),
              )}
            </div>
          </section>
        )}

        {supportedBy.length > 0 && (
          <section>
            <h2 class="mb-3 text-xl font-semibold">Supported By</h2>
            <div class="flex flex-wrap gap-2">
              {supportedBy.map(({ id, name, url, company }) =>
                company ? (
                  <a
                    href={`/companies/${company.slug}`}
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {company.name}
                  </a>
                ) : id !== null ? (
                  <BrokenLink id={id} type="company" />
                ) : url ? (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                  >
                    {name}
                  </a>
                ) : (
                  <span class="inline-flex items-center rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium shadow-sm">
                    {name}
                  </span>
                ),
              )}
            </div>
          </section>
        )}

        {/* Awards */}
        {hasAwards && (
          <section>
            <h2 class="mb-4 text-xl font-semibold">Awards</h2>
            <div class="space-y-2">
              {sortedAwards.slice(0, 6).map((award) => (
                <div class="flex items-center justify-between rounded-lg border border-border bg-card px-4 py-3">
                  <div class="flex items-center gap-3">
                    <svg
                      class:list={["h-5 w-5 shrink-0", award.status === "won" ? "text-highlight" : "text-muted-foreground"]}
                      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    >
                      <circle cx="12" cy="8" r="6" />
                      <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11" />
                    </svg>
                    <div>
                      <p class="text-sm font-medium">{award.name}</p>
                      <p class="text-xs text-muted-foreground">{award.year}</p>
                    </div>
                  </div>
                  <span
                    class:list={[
                      "inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-semibold",
                      award.status === "won"
                        ? "border-highlight/40 bg-highlight/10 text-highlight"
                        : "border-border bg-muted text-muted-foreground",
                    ]}
                  >
                    {getAwardStatusLabel(award.status)}
                  </span>
                </div>
              ))}
            </div>
            {sortedAwards.length > 6 && (
              <div id="awards-overflow" class="mt-2 hidden space-y-2">
                {sortedAwards.slice(6).map((award) => (
                  <div class="flex items-center justify-between rounded-lg border border-border bg-card px-4 py-3">
                    <div class="flex items-center gap-3">
                      <svg
                        class:list={["h-5 w-5 shrink-0", award.status === "won" ? "text-highlight" : "text-muted-foreground"]}
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                      >
                        <circle cx="12" cy="8" r="6" />
                        <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11" />
                      </svg>
                      <div>
                        <p class="text-sm font-medium">{award.name}</p>
                        <p class="text-xs text-muted-foreground">{award.year}</p>
                      </div>
                    </div>
                    <span
                      class:list={[
                        "inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-semibold",
                        award.status === "won"
                          ? "border-highlight/40 bg-highlight/10 text-highlight"
                          : "border-border bg-muted text-muted-foreground",
                      ]}
                    >
                      {getAwardStatusLabel(award.status)}
                    </span>
                  </div>
                ))}
              </div>
            )}
            {sortedAwards.length > 6 && (
              <button
                id="awards-toggle"
                class="mt-3 flex w-full items-center justify-center gap-1.5 rounded-lg border border-border bg-card px-4 py-2.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
              >
                <span id="awards-toggle-label">View all {sortedAwards.length} awards</span>
                <svg id="awards-toggle-icon" class="h-4 w-4 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>
              <script>
                const overflow = document.getElementById("awards-overflow");
                const toggle = document.getElementById("awards-toggle");
                const label = document.getElementById("awards-toggle-label");
                const icon = document.getElementById("awards-toggle-icon");
                const total = overflow?.querySelectorAll(".flex").length ?? 0;

                toggle?.addEventListener("click", () => {
                  const expanded = !overflow?.classList.contains("hidden");
                  overflow?.classList.toggle("hidden", expanded);
                  icon?.classList.toggle("rotate-180", !expanded);
                  if (label) label.textContent = expanded ? `View all ${total + 6} awards` : "Show fewer awards";
                });
              </script>
            )}
          </section>
        )}

        {/* News */}
        {hasNews && (
          <section>
            <h2 class="mb-4 text-xl font-semibold">News</h2>
            <div class="space-y-2">
              {gameNews.map((article) => (
                <a
                  href={article.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-start justify-between gap-4 rounded-lg border border-border bg-card px-4 py-3 transition-colors hover:bg-accent"
                >
                  <div>
                    <p class="text-sm font-medium">{article.title}</p>
                    <p class="mt-0.5 text-xs text-muted-foreground">
                      {article.publication} &middot; {formatDate(article.date)}
                    </p>
                  </div>
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      {/* Sidebar */}
      <div class="space-y-8">
        {/* Developer card */}
        {primaryDev && (
          <div class="rounded-xl border border-border bg-card p-5 shadow">
            <h3 class="mb-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">
              Developer
            </h3>
            <div class="mb-3 flex items-center gap-3">
              <div class={`flex h-10 w-10 items-center justify-center rounded-lg ${primaryDev.logo_bg === "light" ? "bg-white" : primaryDev.logo_bg === "dark" ? "bg-zinc-900" : "bg-muted"}`}>
                {(primaryDev.icon ?? primaryDev.logo) ? (
                  <img
                    src={primaryDev.icon ?? primaryDev.logo!}
                    alt={primaryDev.name}
                    class="h-8 w-8 rounded-md object-contain"
                  />
                ) : (
                  <svg class="h-5 w-5 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" />
                    <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" />
                    <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" />
                  </svg>
                )}
              </div>
              <div>
                <p class="font-semibold">{primaryDev.name}</p>
                {primaryDev.location && (
                  <p class="text-xs text-muted-foreground">{primaryDev.location}</p>
                )}
              </div>
            </div>
            {primaryDev.short_description && (
              <p class="mb-3 text-sm text-muted-foreground">
                {primaryDev.short_description}
              </p>
            )}
            <a
              href={`/companies/${primaryDev.slug}`}
              class="inline-flex h-8 items-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
            >
              View company
            </a>
          </div>
        )}

        {pressKitUrl && (
          <div>
            <a
              href={pressKitUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              <svg
                class="h-4 w-4 shrink-0 text-muted-foreground"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" x2="8" y1="13" y2="13" />
                <line x1="16" x2="8" y1="17" y2="17" />
                <line x1="10" x2="8" y1="9" y2="9" />
              </svg>
              Press kit
            </a>
          </div>
        )}

        {/* Additional developers */}
        {developers.length > 1 && developers.slice(1).map(({ id, name, url, company }) => (
          <div class="rounded-xl border border-border bg-card p-5 shadow">
            <h3 class="mb-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">
              Co-Developer
            </h3>
            {company ? (
              <div>
                <p class="font-semibold">{company.name}</p>
                {company.short_description && (
                  <p class="mt-1 text-sm text-muted-foreground">{company.short_description}</p>
                )}
                <a
                  href={`/companies/${company.slug}`}
                  class="mt-2 inline-flex h-8 items-center rounded-md bg-secondary px-3 text-xs font-medium text-secondary-foreground shadow-sm transition-colors hover:bg-secondary/80"
                >
                  View company
                </a>
              </div>
            ) : url ? (
              <a href={url} target="_blank" rel="noopener noreferrer" class="font-semibold hover:text-primary transition-colors">{name}</a>
            ) : id !== null ? (
              <BrokenLink id={id} type="company" />
            ) : (
              <p class="font-semibold">{name}</p>
            )}
          </div>
        ))}

        {/* Critic Ratings */}
        {criticEntries.length > 0 && (
          <div>
            <h3 class="mb-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">
              Critic Ratings
            </h3>
            <div class="space-y-2">
              {criticEntries.map(([source, value]) => {
                const score = typeof value === "number" ? value : parseFloat(String(value));
                const url = buildCriticUrl(source, game.critic_ids?.[source] ?? game.slug);
                return (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-between rounded-lg border border-border bg-card px-4 py-3 transition-colors hover:bg-accent"
                  >
                    <span class="text-sm font-medium">{criticLabels[source] ?? source}</span>
                    <span
                      class:list={[
                        "text-xl font-bold",
                        isNaN(score)
                          ? "text-muted-foreground"
                          : score >= 75
                            ? "text-green-600 dark:text-green-400"
                            : score >= 50
                              ? "text-yellow-600 dark:text-yellow-400"
                              : "text-red-600 dark:text-red-400",
                      ]}
                    >
                      {!isNaN(score) ? score : value}
                    </span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {/* Database Links */}
        {databaseEntries.length > 0 && (
          <div>
            <h3 class="mb-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">
              Databases
            </h3>
            <div class="flex flex-wrap gap-2">
              {databaseEntries.map(([db, id]) => (
                <a
                  href={buildDatabaseUrl(db, id)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-md border border-border bg-card px-2.5 py-1.5 text-xs font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
                >
                  {databaseLabels[db] ?? db}
                  <svg class="h-3 w-3 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    {/* Footer: suggest a change */}
    <div class="mt-16 border-t border-border pt-6 text-center">
      <p class="text-sm text-muted-foreground">
        See something wrong?{" "}
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-primary hover:underline"
        >
          Suggest a change on GitHub
        </a>
      </p>
    </div>
  </div>

  <script define:vars={{ storeHeadingFields }}>
    import { useWishlistStoreHeading } from "../../lib/gameRelease";

    const el = document.getElementById("store-buy-label");
    if (el) {
      el.textContent = useWishlistStoreHeading(storeHeadingFields, new Date())
        ? "Wishlist"
        : "Buy";
    }
  </script>
</BaseLayout>
