---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CompanyCard from "@/components/home/CompanyCard.astro";
import GameCard from "@/components/home/GameCard.astro";
import EventCard from "@/components/home/EventCard.astro";
import RippleGrid from "@/components/ui/RippleGrid";
import { BrokenLink } from "@/components/ui/broken-link";
import { SITE_TITLE } from "@/lib/constants";
import {
  getAllCompanies,
  getPublicGames,
  getAllEvents,
  getAllNewsArticles,
  getStats,
  safeGetCompany,
  shuffleArray,
} from "@/lib/data";
import { getFirstReleaseSortTimestamp, compareUpcoming } from "@/lib/gameRelease";

const stats = await getStats();
const allCompanies = await getAllCompanies();
const allGames = await getPublicGames();
const allEvents = await getAllEvents();

// Studio Highlight: highlighted companies, shuffled, max 4
const highlightedCompanies = shuffleArray(
  allCompanies.filter((c) => c.highlighted)
).slice(0, 4);

// New Releases: released games, most recently launched first, max 5
// Uses start of release_period (not end) so ongoing titles don't float up
const newReleases = allGames
  .filter((g) => g.status === "released" && g.cover_image && typeof g.release_date === "string" && g.release_date.split("-").length === 3)
  .sort(
    (a, b) =>
      getFirstReleaseSortTimestamp(b) - getFirstReleaseSortTimestamp(a),
  )
  .slice(0, 5);

// Upcoming Games: exact date → year+month → year only → TBA
// Exclude any in_development game whose full release date has already passed
const today = new Date();
today.setHours(0, 0, 0, 0);
const upcomingGames = allGames
  .filter((g) => {
    if (g.status !== "in_development") return false;
    if (g.release_date && /^\d{4}-\d{2}-\d{2}$/.test(g.release_date)) {
      return new Date(g.release_date) >= today;
    }
    return true;
  })
  .sort(compareUpcoming)
  .slice(0, 5);

// Resolve developer names for game cards
function shortName(name: string): string {
  return name.replace(/\s*\([^)]*\)\s*$/, "").trim();
}

async function resolveDeveloper(game: typeof newReleases[number]): Promise<string> {
  const devRef = game.companies.developer[0];
  if (!devRef) return "Unknown developer";
  if (typeof devRef === "object") return shortName(devRef.name);
  const company = await safeGetCompany(devRef, "homepage");
  return company ? shortName(company.name) : "Unknown developer";
}

const newReleaseDevelopers = await Promise.all(newReleases.map(resolveDeveloper));
const upcomingDevelopers = await Promise.all(upcomingGames.map(resolveDeveloper));

// Upcoming Events: next 4 soonest, regardless of highlighted status
const now = new Date();
const upcomingEvents = allEvents
  .filter((e) => new Date(e.date_start) >= now)
  .sort((a, b) => new Date(a.date_start).getTime() - new Date(b.date_start).getTime())
  .slice(0, 4);

// ── Ecosystem News ────────────────────────────────────────────────────────────

const allNews = await getAllNewsArticles(); // already sorted newest-first

// Column 1: ecosystem-flagged articles
const ecosystemNews = allNews.filter((n) => n.ecosystem).slice(0, 5);

// Column 2: articles linked to companies or games, with source tag pre-computed
const companyNameMap = new Map(allCompanies.map((c) => [c.id, { name: c.name, slug: c.slug }]));
const gameNameMap = new Map(allGames.map((g) => [g.id, { title: g.title, slug: g.slug }]));

interface StudioNewsItem {
  id: string; title: string; publication: string; date: string; url: string;
  sourceTag: string | null;
}
const studioGameNews: StudioNewsItem[] = allNews
  .filter((n) => n.company_ids.length > 0 || n.game_ids.length > 0)
  .slice(0, 5)
  .map((n) => {
    let sourceTag: string | null = null;
    if (n.company_ids[0]) sourceTag = companyNameMap.get(n.company_ids[0])?.name ?? null;
    if (!sourceTag && n.game_ids[0]) sourceTag = gameNameMap.get(n.game_ids[0])?.title ?? null;
    return { id: n.id, title: n.title, publication: n.publication, date: n.date, url: n.url, sourceTag };
  });

// Column 3: Scottish Games Network RSS feed (fetched at build time)
interface SgnPost { title: string; link: string; pubDate: string; }
let sgnPosts: SgnPost[] = [];
try {
  const rssText = await fetch("https://scottishgames.net/feed/", {
    headers: { "User-Agent": "gamesindustry.scot/1.0 RSS reader" },
    signal: AbortSignal.timeout(8000),
  }).then((r) => r.text());
  for (const m of rssText.matchAll(/<item>([\s\S]*?)<\/item>/g)) {
    const b = m[1];
    const title = (b.match(/<title>(?:<!\[CDATA\[)?([\s\S]*?)(?:\]\]>)?<\/title>/) ?? [])[1]?.trim() ?? "";
    const link  = (b.match(/<link>(https?:\/\/[^<]+)<\/link>/) ?? [])[1]?.trim() ?? "";
    const pubDate = (b.match(/<pubDate>([\s\S]*?)<\/pubDate>/) ?? [])[1]?.trim() ?? "";
    if (title && link) { sgnPosts.push({ title, link, pubDate }); if (sgnPosts.length >= 5) break; }
  }
} catch { /* fail silently during build */ }

function fmtDate(dateStr: string): string {
  try {
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    const days = Math.floor((Date.now() - d.getTime()) / 86400000);
    if (days === 0) return "Today";
    if (days === 1) return "Yesterday";
    if (days < 7) return `${days}d ago`;
    if (days < 60) return `${Math.floor(days / 7)}w ago`;
    return d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
  } catch { return dateStr; }
}

const sections = [
  { label: "Companies",  href: "/companies",  icon: "building",   stat: stats.companies,     subLabel: "active" },
  { label: "Games",      href: "/games",      icon: "gamepad",    stat: stats.games,          subLabel: "releases" },
  { label: "Freelancers",href: "/freelancers",icon: "usercheck",  stat: stats.freelancers,    subLabel: "profiles" },
  { label: "Jobs",       href: "/jobs",       icon: "briefcase",  stat: stats.jobs,           subLabel: "posted" },
  { label: "Education",  href: "/education",  icon: "graduation", stat: stats.schools,        subLabel: "institutions" },
  { label: "Events",     href: "/events",     icon: "calendar",   stat: stats.upcomingEvents, subLabel: "upcoming" },
];
---

<BaseLayout title={SITE_TITLE}>
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 sm:py-32">
    <div class="absolute inset-0 -z-10 ripple-wrapper">
      <RippleGrid
        client:only="react"
        gridColor="#4a90d9"
        rippleIntensity={0.04}
        gridSize={10}
        gridThickness={12}
        fadeDistance={1.2}
        vignetteStrength={1.5}
        glowIntensity={0.15}
        opacity={0.6}
        gridRotation={45}
        mouseInteraction={true}
        mouseInteractionRadius={0.6}
      />
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center relative">
      <div class="hero-fade-in">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          <span class="block text-muted-foreground text-xl sm:text-2xl lg:text-3xl font-medium mb-3">Explore the</span>
          <span class="text-foreground">Scottish Games Industry</span>
        </h1>
        <p class="mt-6 mx-auto max-w-2xl text-base sm:text-lg text-muted-foreground">
          The open directory of the Scottish games industry.<br />Development studios, publishers, games, and professionals based in Scotland.
        </p>
        <div class="mt-8 flex items-center justify-center gap-1">
          <span class="text-xs text-muted-foreground/70">Supported by</span>
          <a href="https://buildstash.com" target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
            <img src="/images/buildstash-logo-full-dark.svg" alt="Buildstash" style="height:18px;width:auto;" class="hidden dark:block" />
            <img src="/images/buildstash-logo-full-light.svg" alt="Buildstash" style="height:18px;width:auto;" class="dark:hidden" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Nav -->
  <section class="relative -mt-8 pb-10 z-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <nav class="flex items-stretch gap-1 rounded-2xl border border-border bg-card/80 backdrop-blur-sm p-1.5 shadow-lg">
        {sections.map((s) => (
          <a
            href={s.href}
            class="group flex flex-1 flex-col items-center gap-1 rounded-xl px-2 py-3 text-center transition-all hover:bg-accent"
          >
            <!-- Icon -->
            <span class="flex h-7 w-7 items-center justify-center rounded-md bg-muted/60 text-muted-foreground transition-colors group-hover:bg-primary/10 group-hover:text-primary">
              {s.icon === "building" && (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
              )}
              {s.icon === "gamepad" && (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1.11 0 2.08-.402 2.592-1.382l.375-.646a1 1 0 0 1 .866-.498h6.334a1 1 0 0 1 .866.498l.375.646C16.92 18.598 17.89 19 19 19a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.152A4 4 0 0 0 17.32 5z"/></svg>
              )}
              {s.icon === "usercheck" && (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>
              )}
              {s.icon === "briefcase" && (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
              )}
              {s.icon === "graduation" && (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/></svg>
              )}
              {s.icon === "calendar" && (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              )}
            </span>
            <!-- Label — prominent headline -->
            <span class="text-xs font-semibold text-foreground group-hover:text-primary transition-colors leading-tight">{s.label}</span>
            <!-- Stat + sub-label on one line — secondary context -->
            {s.stat !== null && s.subLabel && (
              <span class="text-[10px] tabular-nums text-muted-foreground/70 leading-tight">
                <span class="font-semibold text-muted-foreground">{s.stat}</span> {s.subLabel}
              </span>
            )}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- New Releases -->
  {newReleases.length > 0 && (
    <section class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">New Releases</h2>
          <a href="/games/list?sort=release_date_newest&status=released" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
          {newReleases.map((game, i) => (
            <GameCard game={game} developerName={newReleaseDevelopers[i]} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <section class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">Upcoming Events</h2>
          <a href="/events" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {upcomingEvents.map((event) => (
            <EventCard event={event} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Ecosystem News -->
  {(ecosystemNews.length > 0 || studioGameNews.length > 0 || sgnPosts.length > 0) && (
    <section class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold tracking-tight mb-8">News</h2>
        <div class="grid gap-6 lg:grid-cols-3">

          <!-- Col 1: Ecosystem News -->
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Ecosystem News</h3>
            {ecosystemNews.length > 0 ? (
              <div class="divide-y divide-border rounded-xl border border-border bg-card overflow-hidden">
                {ecosystemNews.map((item) => (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex flex-col gap-1.5 px-4 py-3 transition-colors hover:bg-accent/50"
                  >
                    <span class="text-sm font-medium leading-snug group-hover:text-primary transition-colors line-clamp-2">
                      {item.title}
                    </span>
                    <div class="flex items-center gap-1.5 text-xs text-muted-foreground">
                      <span>{item.publication}</span>
                      <span class="ml-auto tabular-nums">{fmtDate(item.date)}</span>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <p class="rounded-xl border border-dashed border-border px-4 py-6 text-center text-sm text-muted-foreground">No ecosystem news yet.</p>
            )}
          </div>

          <!-- Col 2: Studio & Game Updates -->
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Studio &amp; Game Updates</h3>
            {studioGameNews.length > 0 ? (
              <div class="divide-y divide-border rounded-xl border border-border bg-card overflow-hidden">
                {studioGameNews.map((item) => (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex flex-col gap-1.5 px-4 py-3 transition-colors hover:bg-accent/50"
                  >
                    <span class="text-sm font-medium leading-snug group-hover:text-primary transition-colors line-clamp-2">
                      {item.title}
                    </span>
                    <div class="flex items-center gap-1.5 text-xs text-muted-foreground">
                      <span>{item.publication}</span>
                      {item.sourceTag && (
                        <span class="rounded-full border border-border bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground leading-none">
                          {item.sourceTag}
                        </span>
                      )}
                      <span class="ml-auto tabular-nums">{fmtDate(item.date)}</span>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <p class="rounded-xl border border-dashed border-border px-4 py-6 text-center text-sm text-muted-foreground">No studio news yet.</p>
            )}
          </div>

          <!-- Col 3: Scottish Games Network Blog -->
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Scottish Games Network Blog</h3>
            {sgnPosts.length > 0 ? (
              <>
                <div class="divide-y divide-border rounded-xl border border-border bg-card overflow-hidden">
                  {sgnPosts.map((post) => (
                    <a
                      href={post.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group flex flex-col gap-1.5 px-4 py-3 transition-colors hover:bg-accent/50"
                    >
                      <span class="text-sm font-medium leading-snug group-hover:text-primary transition-colors line-clamp-2">
                        {post.title}
                      </span>
                      <div class="flex items-center gap-1.5 text-xs text-muted-foreground">
                        <span>scottishgames.net</span>
                        <span class="ml-auto tabular-nums">{fmtDate(post.pubDate)}</span>
                      </div>
                    </a>
                  ))}
                </div>
                <div class="mt-2 text-right">
                  <a
                    href="https://scottishgames.net"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-muted-foreground transition-colors hover:text-foreground hover:underline"
                  >
                    More at scottishgames.net &rarr;
                  </a>
                </div>
              </>
            ) : (
              <p class="rounded-xl border border-dashed border-border px-4 py-6 text-center text-sm text-muted-foreground">Could not load feed.</p>
            )}
          </div>

        </div>
      </div>
    </section>
  )}

  <!-- Studio Highlight -->
  {highlightedCompanies.length > 0 && (
    <section class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">Studio Highlight</h2>
          <a href="/companies" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {highlightedCompanies.map((company) => (
            <CompanyCard company={company} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Upcoming Games -->
  {upcomingGames.length > 0 && (
    <section class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">Upcoming Games</h2>
          <a href="/games/list?sort=release_date_oldest&status=in_development" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            View all &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
          {upcomingGames.map((game, i) => (
            <GameCard game={game} developerName={upcomingDevelopers[i]} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Sponsor Block -->
  <section class="py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-border bg-muted/50 px-8 py-8">
        <div class="grid grid-cols-1 sm:grid-cols-[240px_1px_1fr] items-center gap-6">
          <!-- Logo + label: single inline-flex column — label is literally the line above the logo -->
          <a
            href="https://buildstash.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex flex-col items-center gap-2 opacity-80 hover:opacity-100 transition-opacity"
          >
            <span class="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground/70">Built and supported by</span>
            <img src="/images/buildstash-logo-full-dark.svg" alt="Buildstash" style="height:44px;width:auto;" class="hidden dark:block" />
            <img src="/images/buildstash-logo-full-light.svg" alt="Buildstash" style="height:44px;width:auto;" class="dark:hidden" />
          </a>
          <!-- Divider -->
          <div class="hidden sm:block h-full w-px bg-border self-stretch"></div>
          <!-- Description + CTA -->
          <div class="flex flex-col gap-3 text-center sm:text-left">
            <p class="text-sm text-muted-foreground">
              Software binary management. Organize and share playable builds for any platform across your team, QA, external testers, and collaborators.
            </p>
            <div>
              <a
                href="https://buildstash.com"
                class="inline-flex items-center gap-1 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
                target="_blank"
                rel="noopener noreferrer"
              >
                Learn more
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" x2="21" y1="14" y2="3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-fade-in {
    animation: hero-fade-up 0.8s ease-out both;
  }
</style>
<style is:global>
  .ripple-wrapper {
    opacity: 0.45;
    mask-image: radial-gradient(ellipse at center, black 15%, transparent 55%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 15%, transparent 55%);
  }
  .dark .ripple-wrapper {
    opacity: 1;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }
</style>
