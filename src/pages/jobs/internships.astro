---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getActiveJobs, getAllCompanies } from "@/lib/data";
import { GITHUB_REPO } from "@/lib/constants";
import JobBoardView from "@/components/jobs/JobBoardView";

const allActive = await getActiveJobs();
const internships = allActive.filter((j) => j.type === "internship");
const companies = await getAllCompanies();

const companyIds = new Set(internships.map((j) => j.company_id));
const relevantCompanies = companies
  .filter((c) => companyIds.has(c.id))
  .map((c) => ({
    id: c.id,
    name: c.name,
    slug: c.slug,
    logo: c.logo ?? undefined,
    short_description: c.short_description ?? undefined,
  }));

const serialized = internships.map((j) => ({
  id: j.id,
  title: j.title,
  slug: j.slug,
  company_id: j.company_id,
  discipline: j.discipline,
  type: j.type,
  work_mode: j.work_mode ?? undefined,
  location: j.location ?? undefined,
  date_posted: j.date_posted,
  closing_date: j.closing_date ?? undefined,
  url: j.url,
  description: j.description ?? undefined,
  active: j.active,
}));

const newInternshipUrl = `https://github.com/${GITHUB_REPO}/issues/new?template=new-job.yml`;
---

<BaseLayout title="Internships">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">Internships</h1>
      <p class="mt-3 max-w-2xl text-lg text-muted-foreground">
        Explore internship opportunities at Scottish games industry companies.
        A great way to get started in the industry.
      </p>
      <div class="mt-6">
        <a
          href={newInternshipUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
        >
          Post an internship
        </a>
      </div>
    </div>

    {
      internships.length === 0 ? (
        <div class="rounded-xl border border-border bg-card p-8 text-center">
          <p class="text-lg font-medium text-muted-foreground">
            No internships currently listed. Check back soon or post one!
          </p>
        </div>
      ) : (
        <JobBoardView
          client:load
          jobs={serialized}
          companies={relevantCompanies}
        />
      )
    }
  </div>
</BaseLayout>
