---
import BaseLayout from "@/layouts/BaseLayout.astro";
import linksData from "../../data/links.json";
---

<BaseLayout title="Links" description="Helpful links across the Scottish and wider games industry." noindex={true}>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold tracking-tight mb-2">Helpful Links</h1>
    <p class="text-muted-foreground mb-12">
      Useful resources across the Scottish and wider games industry.
    </p>

    {linksData.sections.map((section) => (
      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6">{section.title}</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {section.links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-xl border border-border bg-card p-5 transition-all hover:border-primary/30 hover:shadow-md"
            >
              <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">
                {link.name}
                <svg class="inline-block ml-1 h-4 w-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </h3>
              <p class="mt-1 text-sm text-muted-foreground">{link.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
