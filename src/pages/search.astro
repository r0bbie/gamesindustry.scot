---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllCompanies,
  getPublicGames,
  getAllFreelancers,
  getAllEvents,
  getAllSchools,
  getAllTeams,
  getAllStudentGames,
} from "@/lib/data";

const companies = await getAllCompanies();
const games = await getPublicGames();
const freelancers = await getAllFreelancers();
const events = await getAllEvents();
const schools = await getAllSchools();
const teams = await getAllTeams();
const studentGames = await getAllStudentGames();

const schoolNameById = new Map(schools.map((s) => [s.id, s.name]));

function clipText(text: string | undefined, max: number): string {
  if (!text) return "";
  const oneLine = text.replace(/\s+/g, " ").trim();
  if (oneLine.length <= max) return oneLine;
  return `${oneLine.slice(0, max - 1).trimEnd()}…`;
}

const searchIndex = [
  ...companies.map((c) => ({
    title: c.name,
    description: c.short_description ?? "",
    /** Included in fallback matching so former names (e.g. Digital Bridges → I-Play) are searchable. */
    formerNames: (c.previously_known_as ?? []).join(" "),
    url: `/companies/${c.slug}`,
    type: "Company",
  })),
  ...games.map(g => ({ title: g.title, description: g.short_description ?? "", url: `/games/${g.slug}`, type: "Game" })),
  ...freelancers.map(f => ({ title: f.name, description: f.short_bio ?? f.discipline, url: `/freelancers/${f.slug}`, type: "Freelancer" })),
  ...events.map(e => ({ title: e.name, description: e.short_description ?? "", url: `/events/${e.slug}`, type: "Event" })),
  ...schools.map(s => ({ title: s.name, description: s.about?.slice(0, 120) ?? "", url: `/education/schools/${s.slug}`, type: "School" })),
  ...teams.map((t) => {
    const school = schoolNameById.get(t.school_id) ?? "";
    const parts = [t.short_description ? clipText(t.short_description, 140) : "", school].filter(Boolean);
    return {
      title: t.name,
      description: parts.join(" · "),
      url: `/education/teams/${t.slug}`,
      type: "Student team",
    };
  }),
  ...studentGames.map((g) => {
    const school = schoolNameById.get(g.school_id) ?? "";
    const desc = g.description ? clipText(g.description, 140) : "";
    const parts = [desc, school ? `Student game · ${school}` : "Student game"].filter(Boolean);
    return {
      title: g.title,
      description: parts.join(" · "),
      url: `/education/games/${g.slug}`,
      type: "Student game",
    };
  }),
];
---

<BaseLayout title="Search">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="mb-8 text-3xl font-bold tracking-tight">Search</h1>
    <div id="search">
      <p id="search-loading" class="text-muted-foreground">Loading search...</p>
    </div>
    <div id="fallback-search" class="hidden">
      <input
        id="fallback-input"
        type="text"
        placeholder="Search companies, games, student teams, schools, events..."
        class="w-full rounded-lg border border-input bg-background px-4 py-3 text-base outline-none ring-ring focus:ring-2"
        autofocus
      />
      <div id="fallback-results" class="mt-4 space-y-2"></div>
    </div>
  </div>

  <script is:inline define:vars={{ searchIndex }}>
    (function () {
      var link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "/pagefind/pagefind-ui.css";
      link.onerror = function () {};
      document.head.appendChild(link);

      // Map Pagefind UI's theme variables onto the site's existing tokens so
      // it tracks the .dark class on <html>. Appended *after* the Pagefind
      // stylesheet so our values win on the cascade — same-specificity rules
      // are resolved by DOM order, not load order.
      var themeStyle = document.createElement("style");
      themeStyle.textContent = [
        ":root {",
        "  --pagefind-ui-primary: var(--primary);",
        "  --pagefind-ui-text: var(--foreground);",
        "  --pagefind-ui-background: var(--background);",
        "  --pagefind-ui-border: var(--border);",
        "  --pagefind-ui-tag: var(--muted);",
        "  --pagefind-ui-border-radius: 0.5rem;",
        "}",
      ].join("\n");
      document.head.appendChild(themeStyle);

      function showFallback() {
        var el = document.getElementById("search-loading");
        if (el) el.remove();
        var fallback = document.getElementById("fallback-search");
        fallback.classList.remove("hidden");

        var input = document.getElementById("fallback-input");
        var results = document.getElementById("fallback-results");

        input.addEventListener("input", function () {
          var q = input.value.toLowerCase().trim();
          results.innerHTML = "";
          if (!q) return;
          var matches = searchIndex.filter(function (item) {
            var former = item.formerNames ? item.formerNames.toLowerCase() : "";
            return (
              item.title.toLowerCase().includes(q) ||
              item.description.toLowerCase().includes(q) ||
              former.includes(q) ||
              item.type.toLowerCase().includes(q)
            );
          }).slice(0, 20);

          if (matches.length === 0) {
            results.innerHTML =
              '<p class="text-muted-foreground text-sm">No results found.</p>';
            return;
          }

          matches.forEach(function (item) {
            var a = document.createElement("a");
            a.href = item.url;
            a.className =
              "block rounded-lg border border-border bg-card p-3 transition-colors hover:border-primary/30";
            a.innerHTML =
              '<div class="flex items-center justify-between">' +
              '<span class="font-medium">' + item.title + "</span>" +
              '<span class="text-xs text-muted-foreground rounded bg-secondary px-2 py-0.5">' + item.type + "</span>" +
              "</div>" +
              (item.description
                ? '<p class="mt-1 text-sm text-muted-foreground line-clamp-1">' + item.description + "</p>"
                : "");
            results.appendChild(a);
          });
        });
      }

      // Pagefind UI renders the result thumb as a plain <div> — wrap its
      // contents in an <a> pointing to the same URL as the result title so
      // clicking the image navigates too. Uses display:contents so the link
      // is invisible to layout.
      function linkifyThumbs(root) {
        var results = root.querySelectorAll(".pagefind-ui__result");
        for (var i = 0; i < results.length; i++) {
          var result = results[i];
          var thumb = result.querySelector(".pagefind-ui__result-thumb");
          var titleLink = result.querySelector(".pagefind-ui__result-link");
          if (!thumb || !titleLink || thumb.dataset.linkified) continue;
          if (thumb.classList.contains("pagefind-ui__loading")) continue;
          thumb.dataset.linkified = "1";
          var a = document.createElement("a");
          a.href = titleLink.getAttribute("href");
          a.style.display = "contents";
          while (thumb.firstChild) a.appendChild(thumb.firstChild);
          thumb.appendChild(a);
        }
      }

      function startThumbObserver() {
        var searchEl = document.getElementById("search");
        if (!searchEl) return;
        var observer = new MutationObserver(function () {
          linkifyThumbs(searchEl);
        });
        observer.observe(searchEl, { childList: true, subtree: true });
      }

      import("/pagefind/pagefind-ui.js")
        .then(function (module) {
          try {
            var el = document.getElementById("search-loading");
            if (el) el.remove();
            var UI = module.PagefindUI || window.PagefindUI;
            if (!UI) throw new Error("PagefindUI not found");
            new UI({
              element: "#search",
              showSubResults: true,
              autofocus: true,
              // Replace Pagefind's auto-generated excerpt (which can read
              // like "Games Industry Denki Development Studio. Dundee Dundee
              // studio behind…") with our hand-crafted summary meta when the
              // page provides one.
              processResult: function (result) {
                if (result && result.meta && result.meta.summary) {
                  result.excerpt = result.meta.summary;
                }
                return result;
              },
            });
            startThumbObserver();
          } catch (e) {
            showFallback();
          }
        })
        .catch(showFallback);
    })();
  </script>
</BaseLayout>
